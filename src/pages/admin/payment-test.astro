---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';

if (!Astro.locals.user) {
  return Astro.redirect('/admin/login');
}
---

<Layout title="결제 테스트 대시보드 - issac.design Admin" noindex={true}>
  <script is:inline>document.body.classList.add('preloader-ready');</script>

  <main class="payment-page">
    <div class="payment-test">
      <div class="payment-test__header">
        <h1 class="payment-test__title">결제 테스트 대시보드</h1>
        <p class="payment-test__subtitle">Toss Payments 연동 테스트 시나리오 (10개)</p>
      </div>

      <div class="payment-test__card-info">
        <h3 class="payment-test__card-info-title">테스트 카드 정보</h3>
        <div class="payment-test__card-info-row">
          <span class="payment-test__card-info-label">카드번호</span>
          <span class="payment-test__card-info-value">4330 1234 5678 1234</span>
        </div>
        <div class="payment-test__card-info-row">
          <span class="payment-test__card-info-label">유효기간</span>
          <span class="payment-test__card-info-value">아무 미래 날짜 (예: 12/30)</span>
        </div>
        <div class="payment-test__card-info-row">
          <span class="payment-test__card-info-label">CVC</span>
          <span class="payment-test__card-info-value">아무 3자리 (예: 123)</span>
        </div>
      </div>

      <div class="payment-test__scenarios">

        <div class="payment-test__scenario" data-scenario="1">
          <div class="payment-test__scenario-header">
            <span class="payment-test__scenario-num">1</span>
            <span class="payment-test__scenario-title">카드 결제 성공</span>
          </div>
          <p class="payment-test__scenario-desc">테스트 주문(50,000원)을 생성하고 결제 위젯을 통해 카드 결제를 진행합니다.</p>
          <div class="payment-test__scenario-actions">
            <button class="payment-test__run-btn" data-test="1" type="button">테스트 실행</button>
          </div>
          <div class="payment-test__log" data-log="1"></div>
        </div>

        <div class="payment-test__scenario" data-scenario="2">
          <div class="payment-test__scenario-header">
            <span class="payment-test__scenario-num">2</span>
            <span class="payment-test__scenario-title">사용자 취소</span>
          </div>
          <p class="payment-test__scenario-desc">결제 창에서 사용자가 취소 버튼을 누르는 시나리오. 시나리오 1 실행 후 결제 창에서 닫기/취소를 눌러주세요.</p>
          <div class="payment-test__scenario-actions">
            <button class="payment-test__run-btn" data-test="2" type="button">테스트 실행</button>
          </div>
          <div class="payment-test__log" data-log="2"></div>
        </div>

        <div class="payment-test__scenario" data-scenario="3">
          <div class="payment-test__scenario-header">
            <span class="payment-test__scenario-num">3</span>
            <span class="payment-test__scenario-title">금액 변조</span>
          </div>
          <p class="payment-test__scenario-desc">결제 승인 시 서버에 변조된 금액을 전송합니다. 서버에서 금액 불일치를 감지해야 합니다.</p>
          <div class="payment-test__scenario-actions">
            <button class="payment-test__run-btn" data-test="3" type="button">테스트 실행</button>
          </div>
          <div class="payment-test__log" data-log="3"></div>
        </div>

        <div class="payment-test__scenario" data-scenario="4">
          <div class="payment-test__scenario-header">
            <span class="payment-test__scenario-num">4</span>
            <span class="payment-test__scenario-title">중복 승인</span>
          </div>
          <p class="payment-test__scenario-desc">동일한 paymentKey로 confirm 엔드포인트를 2회 호출합니다. 두 번째 요청은 거절되어야 합니다.</p>
          <div class="payment-test__scenario-actions">
            <button class="payment-test__run-btn" data-test="4" type="button">테스트 실행</button>
          </div>
          <div class="payment-test__log" data-log="4"></div>
        </div>

        <div class="payment-test__scenario" data-scenario="5">
          <div class="payment-test__scenario-header">
            <span class="payment-test__scenario-num">5</span>
            <span class="payment-test__scenario-title">결제 후 취소</span>
          </div>
          <p class="payment-test__scenario-desc">결제 완료 후 cancel API를 호출하여 전체 취소를 진행합니다.</p>
          <div class="payment-test__scenario-actions">
            <button class="payment-test__run-btn" data-test="5" type="button">테스트 실행</button>
          </div>
          <div class="payment-test__log" data-log="5"></div>
        </div>

        <div class="payment-test__scenario" data-scenario="6">
          <div class="payment-test__scenario-header">
            <span class="payment-test__scenario-num">6</span>
            <span class="payment-test__scenario-title">결제 후 환불</span>
          </div>
          <p class="payment-test__scenario-desc">결제 완료 후 refund API를 호출하여 전체 환불을 진행합니다.</p>
          <div class="payment-test__scenario-actions">
            <button class="payment-test__run-btn" data-test="6" type="button">테스트 실행</button>
          </div>
          <div class="payment-test__log" data-log="6"></div>
        </div>

        <div class="payment-test__scenario" data-scenario="7">
          <div class="payment-test__scenario-header">
            <span class="payment-test__scenario-num">7</span>
            <span class="payment-test__scenario-title">부분 환불</span>
          </div>
          <p class="payment-test__scenario-desc">결제 완료 후 일부 금액(10,000원)만 환불을 요청합니다.</p>
          <div class="payment-test__scenario-actions">
            <button class="payment-test__run-btn" data-test="7" type="button">테스트 실행</button>
          </div>
          <div class="payment-test__log" data-log="7"></div>
        </div>

        <div class="payment-test__scenario" data-scenario="8">
          <div class="payment-test__scenario-header">
            <span class="payment-test__scenario-num">8</span>
            <span class="payment-test__scenario-title">네트워크 타임아웃</span>
          </div>
          <p class="payment-test__scenario-desc">네트워크 타임아웃은 실제 환경에서만 발생합니다. 서버 측 타임아웃 처리 로직을 코드 리뷰로 확인하세요.</p>
          <div class="payment-test__scenario-actions">
            <button class="payment-test__run-btn payment-test__run-btn--info" data-test="8" type="button" disabled>정보만 제공</button>
          </div>
          <div class="payment-test__log" data-log="8"></div>
        </div>

        <div class="payment-test__scenario" data-scenario="9">
          <div class="payment-test__scenario-header">
            <span class="payment-test__scenario-num">9</span>
            <span class="payment-test__scenario-title">잘못된 API 키</span>
          </div>
          <p class="payment-test__scenario-desc">잘못된 API 키로 결제를 시도하면 SDK 초기화 단계에서 실패합니다. 프로덕션 키 변경 시 발생할 수 있습니다.</p>
          <div class="payment-test__scenario-actions">
            <button class="payment-test__run-btn payment-test__run-btn--info" data-test="9" type="button" disabled>정보만 제공</button>
          </div>
          <div class="payment-test__log" data-log="9"></div>
        </div>

        <div class="payment-test__scenario" data-scenario="10">
          <div class="payment-test__scenario-header">
            <span class="payment-test__scenario-num">10</span>
            <span class="payment-test__scenario-title">Webhook 서명 변조</span>
          </div>
          <p class="payment-test__scenario-desc">가짜 webhook을 잘못된 서명과 함께 전송합니다. 서버에서 서명 검증 실패로 거부해야 합니다.</p>
          <div class="payment-test__scenario-actions">
            <button class="payment-test__run-btn" data-test="10" type="button">테스트 실행</button>
          </div>
          <div class="payment-test__log" data-log="10"></div>
        </div>

      </div>
    </div>
  </main>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const TEST_AMOUNT = 50000;
    let lastOrderId = '';
    let lastPaymentId = '';

    function timestamp(): string {
      return new Date().toLocaleTimeString('ko-KR', { hour12: false });
    }

    function addLog(scenarioNum: number, message: string, status: 'success' | 'error' | 'warn' | 'info') {
      const logEl = document.querySelector(`[data-log="${scenarioNum}"]`) as HTMLElement;
      if (!logEl) return;

      logEl.classList.add('payment-test__log--visible');

      const icons: Record<string, string> = {
        success: '\u2705',
        error: '\u274C',
        warn: '\u26A0\uFE0F',
        info: '\u2139\uFE0F',
      };

      const entry = document.createElement('div');
      entry.className = `payment-test__log-entry payment-test__log-entry--${status}`;
      entry.textContent = `[${timestamp()}] ${icons[status]} ${message}`;
      logEl.appendChild(entry);
      logEl.scrollTop = logEl.scrollHeight;
    }

    function clearLog(scenarioNum: number) {
      const logEl = document.querySelector(`[data-log="${scenarioNum}"]`) as HTMLElement;
      if (logEl) {
        logEl.innerHTML = '';
        logEl.classList.add('payment-test__log--visible');
      }
    }

    async function createTestOrder(scenarioNum: number): Promise<{ orderId: string; amount: number } | null> {
      addLog(scenarioNum, '테스트 주문 생성 중...', 'info');
      try {
        const res = await fetch('/api/payment/create-order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            customer_name: '테스트고객',
            customer_phone: '010-0000-0000',
            items: [{ name: '테스트 상품', quantity: 1, unit_price: TEST_AMOUNT }],
          }),
        });

        const data = await res.json();

        if (!data.success) {
          addLog(scenarioNum, `주문 생성 실패: ${data.error || '알 수 없는 오류'}`, 'error');
          return null;
        }

        lastOrderId = data.data.order_id;
        addLog(scenarioNum, `주문 생성 완료: ${data.data.order_number} (${data.data.amount.toLocaleString()}원)`, 'success');
        return { orderId: data.data.order_id, amount: data.data.amount };
      } catch (err) {
        addLog(scenarioNum, `네트워크 오류: ${err instanceof Error ? err.message : String(err)}`, 'error');
        return null;
      }
    }

    async function runTest1() {
      clearLog(1);
      const order = await createTestOrder(1);
      if (!order) return;

      addLog(1, '결제 페이지로 이동합니다...', 'info');
      localStorage.setItem('paymentCart', JSON.stringify([
        { name: '테스트 상품', quantity: 1, unit_price: TEST_AMOUNT },
      ]));
      localStorage.setItem('paymentCustomerInfo', JSON.stringify({
        name: '테스트고객',
        email: 'test@test.com',
      }));
      window.open('/shop/payment', '_blank');
      addLog(1, '새 탭에서 결제를 진행해주세요.', 'warn');
    }

    async function runTest2() {
      clearLog(2);
      addLog(2, '시나리오 1과 동일하게 결제 페이지를 엽니다.', 'info');
      await runTest1();
      addLog(2, '결제 창에서 취소 버튼을 눌러 PAY_PROCESS_CANCELED 오류를 확인하세요.', 'warn');
    }

    async function runTest3() {
      clearLog(3);
      addLog(3, '금액 변조 테스트 시작', 'info');

      const fakePaymentKey = 'test_pk_tampered_' + Date.now();
      const fakeOrderId = 'test_order_tampered_' + Date.now();
      const tamperedAmount = 100;

      addLog(3, `변조된 금액(${tamperedAmount}원)으로 confirm 호출`, 'warn');

      try {
        const res = await fetch(`/api/payment/confirm?paymentKey=${fakePaymentKey}&orderId=${fakeOrderId}&amount=${tamperedAmount}`);
        const text = await res.text();

        if (res.ok && text.includes('success')) {
          addLog(3, '서버가 변조된 금액을 수락함 — 보안 취약점!', 'error');
        } else {
          addLog(3, `서버 응답: ${res.status} — 금액 변조 감지됨`, 'success');
        }
      } catch (err) {
        addLog(3, `요청 실패: ${err instanceof Error ? err.message : String(err)}`, 'info');
      }
    }

    async function runTest4() {
      clearLog(4);
      addLog(4, '중복 승인 테스트 시작', 'info');

      const fakePaymentKey = 'test_pk_dup_' + Date.now();
      const fakeOrderId = 'test_order_dup_' + Date.now();

      addLog(4, '첫 번째 confirm 호출', 'info');
      try {
        const res1 = await fetch(`/api/payment/confirm?paymentKey=${fakePaymentKey}&orderId=${fakeOrderId}&amount=${TEST_AMOUNT}`);
        addLog(4, `첫 번째 응답: ${res1.status}`, res1.ok ? 'success' : 'warn');

        addLog(4, '두 번째 confirm 호출 (동일 paymentKey)', 'info');
        const res2 = await fetch(`/api/payment/confirm?paymentKey=${fakePaymentKey}&orderId=${fakeOrderId}&amount=${TEST_AMOUNT}`);
        addLog(4, `두 번째 응답: ${res2.status}`, res2.ok ? 'error' : 'success');

        if (!res2.ok) {
          addLog(4, '중복 승인이 정상적으로 거절됨', 'success');
        } else {
          addLog(4, '중복 승인이 허용됨 — 확인 필요', 'error');
        }
      } catch (err) {
        addLog(4, `요청 실패: ${err instanceof Error ? err.message : String(err)}`, 'error');
      }
    }

    async function runTest5() {
      clearLog(5);
      addLog(5, '결제 후 취소 테스트', 'info');

      if (!lastPaymentId && !lastOrderId) {
        addLog(5, '먼저 시나리오 1에서 결제를 완료해주세요.', 'warn');
        return;
      }

      const paymentId = lastPaymentId || lastOrderId;
      addLog(5, `cancel API 호출 — payment_id: ${paymentId}`, 'info');

      try {
        const res = await fetch('/api/payment/cancel', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ payment_id: paymentId, reason: '테스트 취소' }),
        });

        const data = await res.json();
        if (data.success) {
          addLog(5, '취소 성공', 'success');
        } else {
          addLog(5, `취소 실패: ${data.error || '알 수 없는 오류'}`, 'error');
        }
      } catch (err) {
        addLog(5, `요청 실패: ${err instanceof Error ? err.message : String(err)}`, 'error');
      }
    }

    async function runTest6() {
      clearLog(6);
      addLog(6, '결제 후 전체 환불 테스트', 'info');

      if (!lastPaymentId && !lastOrderId) {
        addLog(6, '먼저 시나리오 1에서 결제를 완료해주세요.', 'warn');
        return;
      }

      const paymentId = lastPaymentId || lastOrderId;
      addLog(6, `refund API 호출 (전액) — payment_id: ${paymentId}`, 'info');

      try {
        const res = await fetch('/api/payment/refund', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ payment_id: paymentId, reason: '테스트 전체 환불' }),
        });

        const data = await res.json();
        if (data.success) {
          addLog(6, '전체 환불 성공', 'success');
        } else {
          addLog(6, `환불 실패: ${data.error || '알 수 없는 오류'}`, 'error');
        }
      } catch (err) {
        addLog(6, `요청 실패: ${err instanceof Error ? err.message : String(err)}`, 'error');
      }
    }

    async function runTest7() {
      clearLog(7);
      addLog(7, '부분 환불 테스트 (10,000원)', 'info');

      if (!lastPaymentId && !lastOrderId) {
        addLog(7, '먼저 시나리오 1에서 결제를 완료해주세요.', 'warn');
        return;
      }

      const paymentId = lastPaymentId || lastOrderId;
      addLog(7, `refund API 호출 (10,000원) — payment_id: ${paymentId}`, 'info');

      try {
        const res = await fetch('/api/payment/refund', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ payment_id: paymentId, amount: 10000, reason: '테스트 부분 환불' }),
        });

        const data = await res.json();
        if (data.success) {
          addLog(7, '부분 환불 성공 (10,000원)', 'success');
        } else {
          addLog(7, `부분 환불 실패: ${data.error || '알 수 없는 오류'}`, 'error');
        }
      } catch (err) {
        addLog(7, `요청 실패: ${err instanceof Error ? err.message : String(err)}`, 'error');
      }
    }

    async function runTest10() {
      clearLog(10);
      addLog(10, 'Webhook 서명 변조 테스트', 'info');

      const fakePayload = JSON.stringify({
        eventType: 'PAYMENT_STATUS_CHANGED',
        data: {
          paymentKey: 'fake_pk_' + Date.now(),
          orderId: 'fake_order_' + Date.now(),
          status: 'DONE',
        },
      });

      addLog(10, '변조된 서명으로 webhook 전송', 'warn');

      try {
        const res = await fetch('/api/payment/webhook', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Toss-Signature': 'invalid_fake_signature_' + Date.now(),
          },
          body: fakePayload,
        });

        if (res.status === 401 || res.status === 403 || res.status === 400) {
          addLog(10, `서버가 변조된 서명을 거부함 (${res.status})`, 'success');
        } else if (res.ok) {
          addLog(10, '서버가 변조된 서명을 수락함 — 보안 취약점!', 'error');
        } else {
          addLog(10, `서버 응답: ${res.status}`, 'warn');
        }
      } catch (err) {
        addLog(10, `요청 실패: ${err instanceof Error ? err.message : String(err)}`, 'info');
      }
    }

    const testHandlers: Record<string, () => Promise<void>> = {
      '1': runTest1,
      '2': runTest2,
      '3': runTest3,
      '4': runTest4,
      '5': runTest5,
      '6': runTest6,
      '7': runTest7,
      '10': runTest10,
    };

    document.querySelectorAll<HTMLButtonElement>('[data-test]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const testId = btn.dataset.test || '';
        const handler = testHandlers[testId];
        if (!handler) return;

        btn.disabled = true;
        try {
          await handler();
        } finally {
          btn.disabled = false;
        }
      });
    });
  });
</script>

<style>
  @import '../../styles/payment.css';
</style>
