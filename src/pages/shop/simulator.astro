---
/**
 * 3D Sign Simulator Page
 * Standalone page for the 3D product simulator
 */

import Layout from '../../layouts/Layout.astro';
import ShopNavbar from '../../components/shop/ShopNavbar.astro';
import Breadcrumb from '../../components/shop/Breadcrumb.astro';
import ProductSimulatorSection from '../../components/shop/ProductSimulatorSection.astro';
import ShopFooter from '../../components/shop/ShopFooter.astro';
import Toast from '../../components/shop/Toast.astro';
import SearchOverlay from '../../components/shop/SearchOverlay.astro';
import QuoteCartBadge from '../../components/shop/QuoteCartBadge.astro';

const breadcrumbs = [
  { label: '쇼핑몰', href: '/shop' },
  { label: '3D 시뮬레이터' },
];
---

<Layout
  title="3D 간판 시뮬레이터 - issac.design"
  description="로고를 업로드하고 실제 간판 모습을 3D로 미리 확인해보세요. 금속 채널, 네온 사인, 아크릴 등 다양한 소재를 시뮬레이션할 수 있습니다."
>
  <script is:inline>document.body.classList.add('preloader-ready');</script>
  <ShopNavbar />
  <Toast />
  <SearchOverlay />

  <main class="simulator-page">
    <!-- Breadcrumb -->
    <div class="simulator-page__breadcrumb">
      <Breadcrumb items={breadcrumbs} />
    </div>

    <!-- 3D Simulator -->
    <ProductSimulatorSection />

    <!-- Quote CTA -->
    <section class="simulator-page__cta">
      <div class="simulator-page__cta-container">
        <div class="simulator-page__cta-content">
          <h2 class="simulator-page__cta-title">마음에 드는 디자인을 찾으셨나요?</h2>
          <p class="simulator-page__cta-desc">시뮬레이션 결과를 바탕으로 정확한 견적을 무료로 받아보세요.</p>
          <div class="simulator-page__cta-actions">
            <a href="/shop/quote" class="simulator-page__cta-btn simulator-page__cta-btn--primary">
              <span>무료 견적 요청하기</span>
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="/shop" class="simulator-page__cta-btn simulator-page__cta-btn--secondary">
              <span>제품 둘러보기</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <QuoteCartBadge />
  <ShopFooter />
</Layout>

<style>
  .simulator-page {
    position: relative;
    width: 100%;
    min-height: 100vh;
    background: var(--background);
    padding-top: var(--header-height);
  }

  .simulator-page__breadcrumb {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-lg) var(--container-padding) 0;
  }

  /* CTA Section */
  .simulator-page__cta {
    position: relative;
    width: 100%;
    padding: var(--space-4xl) 0;
    background: var(--surface);
    border-top: 1px solid var(--border);
  }

  .simulator-page__cta-container {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .simulator-page__cta-content {
    text-align: center;
  }

  .simulator-page__cta-title {
    font-size: var(--font-size-2xl);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-md);
  }

  .simulator-page__cta-desc {
    font-size: var(--font-size-base);
    color: var(--text-secondary);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-xl);
  }

  .simulator-page__cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .simulator-page__cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-xl);
    font-size: var(--font-size-sm);
    font-weight: 600;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .simulator-page__cta-btn--primary {
    background: var(--primary);
    color: var(--text-primary);
  }

  .simulator-page__cta-btn--primary:hover {
    background: var(--primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(26, 77, 46, 0.3);
  }

  .simulator-page__cta-btn--secondary {
    background: none;
    border: 1px solid var(--border);
    color: var(--text-secondary);
  }

  .simulator-page__cta-btn--secondary:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  .simulator-page__cta-btn:active {
    transform: translateY(0);
  }

  /* Responsive */
  @media (max-width: 719px) {
    .simulator-page {
      padding-top: var(--header-height-mobile);
    }

    .simulator-page__breadcrumb {
      padding: var(--space-sm) var(--space-sm) 0;
    }

    .simulator-page__cta {
      padding: var(--space-2xl) 0;
    }

    .simulator-page__cta-title {
      font-size: var(--font-size-xl);
    }

    .simulator-page__cta-desc {
      font-size: var(--font-size-sm);
    }

    .simulator-page__cta-actions {
      flex-direction: column;
    }

    .simulator-page__cta-btn {
      width: 100%;
    }
  }
</style>
