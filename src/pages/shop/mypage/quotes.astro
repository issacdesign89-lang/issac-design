</style>

<script>
  function initQuotesPage() {
    document.querySelectorAll<HTMLButtonElement>('.quotes__card-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const card = btn.closest('[data-quote-card]');
        if (!card) return;
        const isExpanded = card.classList.toggle('quotes__card--expanded');
        btn.setAttribute('aria-expanded', String(isExpanded));
      });
    });

    // 결제하기 버튼: 견적 정보를 localStorage에 저장 후 결제 페이지로 이동
    document.querySelectorAll<HTMLAnchorElement>('[data-quote-pay]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const quoteId = btn.dataset.quotePayId;
        const price = btn.dataset.quotePayPrice;
        let products: any[] = [];
        try {
          products = JSON.parse(btn.dataset.quotePayProducts || '[]');
        } catch {}

        // 견적 기반 결제 정보를 localStorage에 저장
        const paymentData = {
          type: 'quote',
          quoteId,
          totalAmount: Math.round(Number(price)),
          products: products.map((p: any) => ({
            productId: p.productId,
            productName: p.productName || '제품',
            categoryName: p.categoryName || '',
            quantity: p.quantity || 1,
            options: p.options || {},
          })),
        };
        localStorage.setItem('pendingPayment', JSON.stringify(paymentData));
        window.location.href = `/shop/payment?quote_id=${quoteId}`;
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initQuotesPage);
  } else {
    initQuotesPage();
  }
</script>
