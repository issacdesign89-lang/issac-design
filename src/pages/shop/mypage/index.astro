---
export const prerender = false;

/**
 * 마이페이지 메인
 * Profile summary, quick stats, navigation to sub-pages
 */

import Layout from '../../../layouts/Layout.astro';
import ShopNavbar from '../../../components/shop/ShopNavbar.astro';
import ShopFooter from '../../../components/shop/ShopFooter.astro';
import { createAstroServerClient } from '../../../lib/supabase-server';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/shop/login?redirect=/shop/mypage');
}

const { supabase } = createAstroServerClient(Astro.request);

const userEmail = user.email ?? '';

const profileResult = await supabase
  .from('profiles')
  .select('*')
  .eq('id' as never, user.id as never)
  .limit(1);

const profile = (profileResult.data as Array<Record<string, any>> | null)?.[0] ?? null;

let orderCountResult = await supabase
  .from('orders')
  .select('*', { count: 'exact', head: true })
  .eq('user_id' as never, user.id as never);

let orderCount = orderCountResult.count;

if (!orderCount && userEmail) {
  orderCountResult = await supabase
    .from('orders')
    .select('*', { count: 'exact', head: true })
    .eq('customer_email' as never, userEmail as never);
  orderCount = orderCountResult.count;
}

const quoteCountResult = await supabase
  .from('quote_requests')
  .select('*', { count: 'exact', head: true })
  .or(`user_id.eq.${user.id},email.eq.${userEmail}` as never);

const quoteCount = quoteCountResult.count;

let latestOrderResult = await supabase
  .from('orders')
  .select('created_at')
  .eq('user_id' as never, user.id as never)
  .order('created_at' as never, { ascending: false })
  .limit(1);

if (!(latestOrderResult.data as Array<Record<string, any>> | null)?.length && userEmail) {
  latestOrderResult = await supabase
    .from('orders')
    .select('created_at')
    .eq('customer_email' as never, userEmail as never)
    .order('created_at' as never, { ascending: false })
    .limit(1);
}

const latestOrder = (latestOrderResult.data as Array<Record<string, any>> | null)?.[0] ?? null;

const displayName = profile?.display_name || user.user_metadata?.full_name || user.email?.split('@')[0] || '회원';
const avatarUrl = profile?.avatar_url || user.user_metadata?.avatar_url || null;
const provider = profile?.provider || user.app_metadata?.provider || 'email';
const initial = displayName.charAt(0).toUpperCase();

function formatDate(dateStr: string | null | undefined): string {
  if (!dateStr) return '-';
  const d = new Date(dateStr);
  return `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
}

const providerLabel: Record<string, string> = {
  google: 'Google',
  kakao: 'Kakao',
  email: '이메일',
};
---

<Layout title="마이페이지 | issac.design" description="내 계정 정보, 주문 내역 확인 및 관리">
  <script is:inline>document.body.classList.add('preloader-ready');</script>
  <ShopNavbar />

  <main class="mypage">
    <div class="mypage__container">
      <h1 class="mypage__heading">마이페이지</h1>

      <!-- Profile Summary -->
      <div class="mypage__profile">
        <div class="mypage__avatar">
          {avatarUrl ? (
            <img src={avatarUrl} alt={displayName} class="mypage__avatar-img" />
          ) : (
            <span class="mypage__avatar-initial">{initial}</span>
          )}
        </div>
        <div class="mypage__profile-info">
          <h2 class="mypage__name">{displayName}</h2>
          <p class="mypage__email">{user.email}</p>
          <span class={`mypage__provider mypage__provider--${provider}`}>
            {providerLabel[provider] || provider}
          </span>
        </div>
      </div>

      <!-- Quick Stats -->
      <div class="mypage__stats">
        <div class="mypage__stat">
          <span class="mypage__stat-value">{orderCount ?? 0}<span class="mypage__stat-unit">건</span></span>
          <span class="mypage__stat-label">총 주문</span>
        </div>
        <div class="mypage__stat-divider"></div>
        <div class="mypage__stat">
          <span class="mypage__stat-value">{quoteCount ?? 0}<span class="mypage__stat-unit">건</span></span>
          <span class="mypage__stat-label">견적 요청</span>
        </div>
        <div class="mypage__stat-divider"></div>
        <div class="mypage__stat">
          <span class="mypage__stat-value mypage__stat-value--date">{formatDate(latestOrder?.created_at)}</span>
          <span class="mypage__stat-label">최근 주문일</span>
        </div>
      </div>

      <!-- Navigation Grid -->
      <nav class="mypage__nav">
        <a href="/shop/mypage/profile" class="mypage__card">
          <div class="mypage__card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
          <div class="mypage__card-body">
            <h3 class="mypage__card-title">회원정보 수정</h3>
            <p class="mypage__card-desc">이름, 연락처, 비밀번호 변경</p>
          </div>
          <svg class="mypage__card-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </a>

        <a href="/shop/mypage/orders" class="mypage__card">
          <div class="mypage__card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
          <div class="mypage__card-body">
            <h3 class="mypage__card-title">주문 내역</h3>
            <p class="mypage__card-desc">주문 상태 확인 및 상세 보기</p>
          </div>
          <svg class="mypage__card-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </a>

        <a href="/shop/mypage/quotes" class="mypage__card">
          <div class="mypage__card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
              <rect x="9" y="3" width="6" height="4" rx="1"/>
              <path d="M9 14l2 2 4-4"/>
            </svg>
          </div>
          <div class="mypage__card-body">
            <h3 class="mypage__card-title">견적 내역</h3>
            <p class="mypage__card-desc">견적 요청 상태 및 견적 금액 확인</p>
          </div>
          <svg class="mypage__card-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </a>

        <button type="button" class="mypage__card mypage__card--logout" id="logoutBtn">
          <div class="mypage__card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
              <polyline points="16 17 21 12 16 7"/>
              <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
          </div>
          <div class="mypage__card-body">
            <h3 class="mypage__card-title">로그아웃</h3>
            <p class="mypage__card-desc">현재 계정에서 로그아웃</p>
          </div>
        </button>
      </nav>
    </div>
  </main>

  <ShopFooter />
</Layout>

<style>
  .mypage {
    min-height: 100vh;
    background: var(--bg-primary);
    padding: calc(var(--header-height) + var(--space-2xl)) var(--container-padding) var(--space-3xl);
  }

  .mypage__container {
    width: 100%;
    max-width: 640px;
    margin: 0 auto;
  }

  .mypage__heading {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-xl);
    letter-spacing: -0.02em;
  }

  /* Profile Summary */
  .mypage__profile {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-xl);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    margin-bottom: var(--space-lg);
  }

  .mypage__avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    border: 2px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }

  .mypage__avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .mypage__avatar-initial {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
  }

  .mypage__profile-info {
    min-width: 0;
  }

  .mypage__name {
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-xs);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mypage__email {
    font-size: var(--font-size-sm);
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mypage__provider {
    display: inline-block;
    padding: 2px var(--space-sm);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .mypage__provider--google {
    background: rgba(66, 133, 244, 0.12);
    color: #93bbfc;
    border: 1px solid rgba(66, 133, 244, 0.25);
  }

  .mypage__provider--kakao {
    background: rgba(254, 229, 0, 0.1);
    color: #e5cf00;
    border: 1px solid rgba(254, 229, 0, 0.25);
  }

  .mypage__provider--email {
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-secondary);
    border: 1px solid var(--border);
  }

  /* Stats */
  .mypage__stats {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    padding: var(--space-lg) var(--space-xl);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    margin-bottom: var(--space-xl);
  }

  .mypage__stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }

  .mypage__stat-value {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .mypage__stat-value--date {
    font-size: var(--font-size-lg);
  }

  .mypage__stat-unit {
    font-size: var(--font-size-sm);
    font-weight: 400;
    color: var(--text-muted);
    margin-left: 2px;
  }

  .mypage__stat-label {
    font-size: var(--font-size-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .mypage__stat-divider {
    width: 1px;
    height: 40px;
    background: var(--border);
  }

  /* Navigation Cards */
  .mypage__nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .mypage__card {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg) var(--space-xl);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all var(--transition-base);
    cursor: pointer;
    width: 100%;
    text-align: left;
    font-family: inherit;
    font-size: inherit;
    color: inherit;
  }

  .mypage__card:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.15);
    transform: translateY(-1px);
  }

  .mypage__card--logout {
    border-color: rgba(239, 68, 68, 0.15);
  }

  .mypage__card--logout:hover {
    background: rgba(239, 68, 68, 0.06);
    border-color: rgba(239, 68, 68, 0.3);
  }

  .mypage__card-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-secondary);
    flex-shrink: 0;
  }

  .mypage__card--logout .mypage__card-icon {
    color: #fca5a5;
    background: rgba(239, 68, 68, 0.08);
  }

  .mypage__card-body {
    flex: 1;
    min-width: 0;
  }

  .mypage__card-title {
    font-size: var(--font-size-base);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 2px;
  }

  .mypage__card--logout .mypage__card-title {
    color: #fca5a5;
  }

  .mypage__card-desc {
    font-size: var(--font-size-xs);
    color: var(--text-muted);
  }

  .mypage__card-arrow {
    color: var(--text-muted);
    flex-shrink: 0;
    transition: transform var(--transition-base);
  }

  .mypage__card:hover .mypage__card-arrow {
    transform: translateX(3px);
  }

  @media (max-width: 719px) {
    .mypage {
      padding-top: calc(var(--header-height-mobile) + var(--space-xl));
    }

    .mypage__profile {
      padding: var(--space-lg);
    }

    .mypage__avatar {
      width: 52px;
      height: 52px;
    }

    .mypage__avatar-initial {
      font-size: var(--font-size-lg);
    }

    .mypage__stats {
      padding: var(--space-md) var(--space-lg);
    }

    .mypage__stat-value {
      font-size: var(--font-size-xl);
    }

    .mypage__stat-value--date {
      font-size: var(--font-size-base);
    }

    .mypage__card {
      padding: var(--space-md) var(--space-lg);
    }

    .mypage__card-icon {
      width: 40px;
      height: 40px;
    }
  }
</style>

<script>
  const logoutBtn = document.getElementById('logoutBtn');
  logoutBtn?.addEventListener('click', async () => {
    if (!confirm('로그아웃 하시겠습니까?')) return;

    try {
      const res = await fetch('/api/auth/logout', { method: 'POST' });
      if (res.ok) {
        window.location.href = '/shop';
      } else {
        alert('로그아웃에 실패했습니다. 다시 시도해주세요.');
      }
    } catch {
      alert('서버 연결에 실패했습니다.');
    }
  });
</script>
