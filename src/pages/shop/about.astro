---
/**
 * About Page
 * Brand-focused introduction with visual storytelling
 * 8 sections: Hero, Mission, Values, Story+Image, Stats, Portfolio, Testimonials, CTA
 */

import ShopLayout from '../../components/shop/ShopLayout.astro';
import { Image } from 'astro:assets';
import { getPortfolioItems } from '../../lib/data-fetchers';

const { portfolioItems } = await getPortfolioItems();

const breadcrumbs = [
  { label: '쇼핑몰', href: '/shop' },
  { label: '회사 소개' },
];

const testimonials = [
  portfolioItems[0] && {
    text: portfolioItems[0].testimonial,
    client: portfolioItems[0].client,
    location: portfolioItems[0].location,
  },
  portfolioItems[6] && {
    text: portfolioItems[6].testimonial,
    client: portfolioItems[6].client,
    location: portfolioItems[6].location,
  },
  portfolioItems[7] && {
    text: portfolioItems[7].testimonial,
    client: portfolioItems[7].client,
    location: portfolioItems[7].location,
  },
].filter(Boolean) as { text: string; client: string; location: string }[];

const storyImage = portfolioItems[0]?.images?.after;
---

<ShopLayout
  title="회사 소개 - issac.design"
  description="공간에 감성을 더하는 사인 디자인. issac.design은 브랜드의 고유한 이야기를 빛과 형태로 표현합니다."
  breadcrumbs={breadcrumbs}
  showBreadcrumb={false}
>
  <main class="about-page">
    <!-- 1. Hero — Video Background -->
    <section class="about-hero">
      <div class="about-hero__video-wrap">
        <video
          class="about-hero__video"
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          poster="/videos/hero1-poster.jpg"
        >
          <source src="/videos/hero1-opt.webm" type="video/webm" />
          <source src="/videos/hero1-opt.mp4" type="video/mp4" />
        </video>
        <div class="about-hero__overlay"></div>
      </div>
      <div class="about-hero__container">
        <span class="about-hero__label">About issac.design</span>
        <h1 class="about-hero__title">공간에 감성을 더하다</h1>
        <p class="about-hero__subtitle">
          당신의 브랜드가 가진 고유한 이야기를,<br class="hide-mobile" />
          빛과 형태로 표현합니다
        </p>
      </div>
    </section>

    <!-- 2. Mission — Brand Philosophy -->
    <section class="about-mission">
      <div class="about-mission__container">
        <div class="about-mission__quote-mark">&ldquo;</div>
        <blockquote class="about-mission__text">
          좋은 간판은 단순한 표시가 아닙니다.<br />
          공간의 첫인상이자, 브랜드의 얼굴입니다.
        </blockquote>
        <p class="about-mission__sub">
          issac.design은 각 브랜드가 가진 고유한 감성을 읽고,<br class="hide-mobile" />
          그에 어울리는 사인을 디자인합니다
        </p>
      </div>
    </section>

    <!-- 3. Values — Core Values (3 Cards) -->
    <section class="about-values">
      <div class="about-values__container">
        <div class="about-values__grid">
          <!-- Design -->
          <div class="about-values__card">
            <div class="about-values__icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 19l7-7 3 3-7 7-3-3z"/>
                <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/>
                <path d="M2 2l7.586 7.586"/>
                <circle cx="11" cy="11" r="2"/>
              </svg>
            </div>
            <h3 class="about-values__card-title">디자인</h3>
            <p class="about-values__card-desc">
              트렌드를 읽고, 브랜드에 맞는 스타일을 제안합니다.
              매장의 분위기와 조화를 이루는 감각적인 디자인을 추구합니다.
            </p>
          </div>

          <!-- Detail -->
          <div class="about-values__card">
            <div class="about-values__icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <circle cx="12" cy="12" r="6"/>
                <circle cx="12" cy="12" r="2"/>
              </svg>
            </div>
            <h3 class="about-values__card-title">디테일</h3>
            <p class="about-values__card-desc">
              소재 선택부터 조명 색온도까지, 작은 차이가 만드는 큰 인상.
              세심한 디테일로 완성도를 높입니다.
            </p>
          </div>

          <!-- Communication -->
          <div class="about-values__card">
            <div class="about-values__icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
                <path d="M8 10h.01M12 10h.01M16 10h.01"/>
              </svg>
            </div>
            <h3 class="about-values__card-title">소통</h3>
            <p class="about-values__card-desc">
              고객의 비전을 정확히 이해하고, 디자인 과정을 함께합니다.
              시안부터 설치까지 긴밀하게 소통합니다.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 4. Story + Image — 2-Column Layout -->
    <section class="about-story">
      <div class="about-story__container">
        <div class="about-story__grid">
          <div class="about-story__content">
            <span class="about-story__label">Our Story</span>
            <h2 class="about-story__title">우리가 만드는 것</h2>
            <p class="about-story__text">
              issac.design은 '잘 보이는 간판'이 아니라 '잘 어울리는 간판'을 만듭니다.
              매장의 분위기, 거리의 풍경, 브랜드가 지향하는 감성 — 이 모든 것을 고려한
              디자인이 우리의 출발점입니다.
            </p>
            <p class="about-story__text">
              디자인, 제작, 설치를 하나의 흐름으로 진행하면서
              브랜드를 깊이 이해하는 과정을 가장 중요하게 생각합니다.
              단순히 제품을 전달하는 것이 아니라, 고객의 이야기를 듣고
              그에 맞는 형태와 빛을 찾아가는 과정입니다.
            </p>
            <p class="about-story__text">
              우리는 공간과 사람을 잇는 사인을 만듭니다.
              지나가는 이의 시선을 멈추게 하고, 브랜드에 대한 기대를 만들어내는 —
              그런 간판을 목표로 합니다.
            </p>
          </div>
          <div class="about-story__image-wrap">
            {storyImage ? (
              <Image
                src={`${storyImage}&w=800&q=80`}
                alt="issac.design 시공 사례"
                class="about-story__image"
                loading="lazy"
                decoding="async"
                width={800}
                height={600}
                format="webp"
                quality={80}
              />
            ) : (
              <div class="about-story__image" style="display:flex;align-items:center;justify-content:center;background:var(--surface-light)">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- 5. Office Space — Bento Grid with integrated text -->
    <section class="about-office" data-about-office>
      <div class="about-office__container">
        <div class="about-office__bento">
          <!-- Text Cell (spans 2×2) -->
          <div class="about-office__text-cell" data-office-reveal>
            <span class="about-office__label">Our Space</span>
            <h2 class="about-office__title">우리가<br />일하는 공간</h2>
            <p class="about-office__desc">
              서울 성수동에 위치한 issac.design —<br />
              디자인, 제작, 소재 쇼룸이<br />
              하나로 연결된 공간입니다.
            </p>
            <p class="about-office__desc about-office__desc--sub">
              방문 상담 환영합니다
            </p>
          </div>

          <!-- Image Cells -->
          <div class="about-office__cell about-office__cell--a" data-office-reveal>
            <Image src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=600&q=80" alt="디자인 스튜디오" class="about-office__img" loading="lazy" decoding="async" width={600} height={400} format="webp" quality={80} />
            <span class="about-office__cell-label">디자인 스튜디오</span>
          </div>
          <div class="about-office__cell about-office__cell--b" data-office-reveal>
            <Image src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?w=400&q=80" alt="제작 공방" class="about-office__img" loading="lazy" decoding="async" width={600} height={400} format="webp" quality={80} />
            <span class="about-office__cell-label">제작 공방</span>
          </div>
          <div class="about-office__cell about-office__cell--c" data-office-reveal>
            <Image src="https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=600&q=80" alt="소재 쇼룸" class="about-office__img" loading="lazy" decoding="async" width={600} height={400} format="webp" quality={80} />
            <span class="about-office__cell-label">소재 쇼룸</span>
          </div>
          <div class="about-office__cell about-office__cell--d" data-office-reveal>
            <Image src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=600&q=80" alt="고객 미팅룸" class="about-office__img" loading="lazy" decoding="async" width={600} height={400} format="webp" quality={80} />
            <span class="about-office__cell-label">고객 미팅룸</span>
          </div>
          <div class="about-office__cell about-office__cell--e" data-office-reveal>
            <Image src="https://images.unsplash.com/photo-1565793298595-6a879b1d9492?w=600&q=80" alt="품질 검수" class="about-office__img" loading="lazy" decoding="async" width={600} height={400} format="webp" quality={80} />
            <span class="about-office__cell-label">품질 검수</span>
          </div>
          <div class="about-office__cell about-office__cell--f" data-office-reveal>
            <Image src="https://images.unsplash.com/photo-1524758631624-e2822e304c36?w=400&q=80" alt="완제품 보관" class="about-office__img" loading="lazy" decoding="async" width={600} height={400} format="webp" quality={80} />
            <span class="about-office__cell-label">완제품 보관</span>
          </div>
        </div>
      </div>
    </section>

    <!-- 6. Stats — Numbers with Emotional Tone -->
    <section class="about-stats">
      <div class="about-stats__container">
        <div class="about-stats__grid">
          <div class="about-stats__card">
            <span class="about-stats__number">15+</span>
            <span class="about-stats__label">Years of Design</span>
            <p class="about-stats__desc">디자인 감각을 다듬어온 시간</p>
          </div>
          <div class="about-stats__card">
            <span class="about-stats__number">1,000+</span>
            <span class="about-stats__label">Unique Signs</span>
            <p class="about-stats__desc">각기 다른 이야기를 담은 간판</p>
          </div>
          <div class="about-stats__card">
            <span class="about-stats__number">6</span>
            <span class="about-stats__label">Product Lines</span>
            <p class="about-stats__desc">다양한 스타일의 제품 라인업</p>
          </div>
          <div class="about-stats__card">
            <span class="about-stats__number">24h</span>
            <span class="about-stats__label">Support</span>
            <p class="about-stats__desc">설치 후에도 함께합니다</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 7. Testimonials — Customer Stories -->
    <section class="about-testimonials">
      <div class="about-testimonials__container">
        <div class="about-testimonials__header">
          <span class="about-testimonials__label">Testimonials</span>
          <h2 class="about-testimonials__title">고객의 이야기</h2>
        </div>
        <div class="about-testimonials__grid">
          {testimonials.map((item) => (
            <div class="about-testimonials__card">
              <div class="about-testimonials__quote-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" opacity="0.3">
                  <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"/>
                </svg>
              </div>
              <p class="about-testimonials__text">{item.text}</p>
              <div class="about-testimonials__author">
                <span class="about-testimonials__name">{item.client}</span>
                <span class="about-testimonials__location">{item.location}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 8. CTA — Call to Action -->
    <section class="about-cta">
      <div class="about-cta__container">
        <h2 class="about-cta__title">당신의 브랜드에 어울리는 간판,<br class="hide-mobile" /> 함께 만들어볼까요?</h2>
        <div class="about-cta__buttons">
          <a href="/shop/quote" class="about-cta__btn about-cta__btn--primary">
            <span>무료 견적 문의</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="tel:070-8873-8472" class="about-cta__btn about-cta__btn--secondary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
            </svg>
            <span>전화 상담</span>
          </a>
        </div>
      </div>
    </section>
  </main>
</ShopLayout>

<style>
  .about-page {
    position: relative;
    width: 100%;
    min-height: 100vh;
    background: var(--background);
  }

  .hide-mobile {
    display: inline;
  }

  /* ===== 1. Hero Section (Video) ===== */
  .about-hero {
    position: relative;
    width: 100%;
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4xl) 0;
    padding-top: calc(var(--header-height) + var(--space-4xl));
    text-align: center;
    overflow: hidden;
  }

  .about-hero__video-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .about-hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.6) 0%,
      rgba(0, 0, 0, 0.5) 50%,
      rgba(0, 0, 0, 0.7) 100%
    );
  }

  .about-hero__container {
    position: relative;
    z-index: 1;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  @keyframes aboutHeroFadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .about-hero__label {
    display: inline-block;
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--primary-light);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: var(--space-lg);
    opacity: 0;
    animation: aboutHeroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  }

  .about-hero__title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
    color: var(--text-primary);
    margin-bottom: var(--space-lg);
    opacity: 0;
    animation: aboutHeroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
  }

  .about-hero__subtitle {
    font-size: var(--font-size-xl);
    color: var(--text-secondary);
    line-height: var(--line-height-relaxed);
    opacity: 0;
    animation: aboutHeroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards;
  }

  /* ===== 2. Mission Section ===== */
  .about-mission {
    position: relative;
    width: 100%;
    padding: var(--space-4xl) 0;
    text-align: center;
  }

  .about-mission__container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .about-mission__quote-mark {
    font-size: 6rem;
    line-height: 1;
    color: var(--primary);
    opacity: 0.3;
    margin-bottom: calc(-1 * var(--space-xl));
    font-family: Georgia, serif;
  }

  .about-mission__text {
    font-size: var(--font-size-2xl);
    font-weight: 500;
    color: var(--text-primary);
    line-height: var(--line-height-relaxed);
    margin: 0 0 var(--space-xl);
    border: none;
    padding: 0;
  }

  .about-mission__sub {
    font-size: var(--font-size-lg);
    color: var(--text-secondary);
    line-height: var(--line-height-relaxed);
  }

  /* ===== 3. Values Grid ===== */
  .about-values {
    position: relative;
    width: 100%;
    padding: var(--space-4xl) 0;
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .about-values__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .about-values__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .about-values__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-2xl) var(--space-xl);
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    transition: transform var(--transition-base), border-color var(--transition-base);
  }

  .about-values__card:hover {
    transform: translateY(-4px);
    border-color: var(--primary);
  }

  .about-values__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background: rgba(76, 175, 80, 0.1);
    border-radius: var(--radius-lg);
    color: var(--primary-light);
    margin-bottom: var(--space-lg);
  }

  .about-values__card-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
  }

  .about-values__card-desc {
    font-size: var(--font-size-base);
    color: var(--text-secondary);
    line-height: var(--line-height-relaxed);
  }

  /* ===== 4. Story + Image ===== */
  .about-story {
    position: relative;
    width: 100%;
    padding: var(--space-4xl) 0;
  }

  .about-story__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .about-story__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .about-story__content {
    order: 1;
  }

  .about-story__label {
    display: inline-block;
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--primary-light);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    margin-bottom: var(--space-sm);
  }

  .about-story__title {
    font-size: var(--font-size-3xl);
    font-weight: 600;
    color: var(--text-primary);
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
    margin-bottom: var(--space-xl);
  }

  .about-story__text {
