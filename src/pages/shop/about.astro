</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initAboutAnimations() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) {
      document.querySelectorAll('[data-office-reveal]').forEach((el) => {
        (el as HTMLElement).style.opacity = '1';
        (el as HTMLElement).style.transform = 'none';
      });
      return;
    }

    // Office section — staggered reveal
    const officeSection = document.querySelector('[data-about-office]');
    if (officeSection) {
      const items = officeSection.querySelectorAll('[data-office-reveal]');
      gsap.to(items, {
        opacity: 1,
        y: 0,
        duration: 0.7,
        stagger: 0.12,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: officeSection,
          start: 'top 75%',
          once: true,
        },
      });
    }

    // Generic fade-up for other sections
    const sections = document.querySelectorAll(
      '.about-mission, .about-values, .about-story, .about-stats, .about-testimonials, .about-cta'
    );
    sections.forEach((section) => {
      const children = section.querySelectorAll(
        '.about-mission__container, .about-values__card, .about-story__content, .about-story__image-wrap, .about-stats__card, .about-testimonials__card, .about-cta__container'
      );
      if (children.length) {
        gsap.fromTo(children,
          { opacity: 0, y: 30 },
          {
            opacity: 1,
            y: 0,
            duration: 0.6,
            stagger: 0.1,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: section,
              start: 'top 80%',
              once: true,
            },
          }
        );
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initAboutAnimations);
  document.addEventListener('astro:page-load', initAboutAnimations);
</script>
