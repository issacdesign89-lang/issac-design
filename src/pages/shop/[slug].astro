---
/**
 * Product Detail Page
 * Dynamic page for individual products with gallery, configurator, and production timeline
 */

import Layout from '../../layouts/Layout.astro';
import ShopNavbar from '../../components/shop/ShopNavbar.astro';
import Breadcrumb from '../../components/shop/Breadcrumb.astro';
import ImageGallery from '../../components/shop/ImageGallery.astro';
import ProductDetail from '../../components/shop/ProductDetail.astro';
import ProductConfigurator from '../../components/shop/ProductConfigurator.astro';
import AddToQuoteButton from '../../components/shop/AddToQuoteButton.astro';
import ProductionTimeline from '../../components/shop/ProductionTimeline.astro';
import RelatedProducts from '../../components/shop/RelatedProducts.astro';

import ShopFooter from '../../components/shop/ShopFooter.astro';
import Toast from '../../components/shop/Toast.astro';
import SearchOverlay from '../../components/shop/SearchOverlay.astro';
import InstallationGallery from '../../components/shop/InstallationGallery.astro';
import QuoteCartBadge from '../../components/shop/QuoteCartBadge.astro';
import ShopAnimations from '../../components/shop/ShopAnimations.astro';
import ScrollProgress from '../../components/ScrollProgress.astro';
import WarrantyBadge from '../../components/shop/WarrantyBadge.astro';
import { getProducts } from '../../lib/data-fetchers';

const { slug } = Astro.params;
const { products } = await getProducts();
const product = products.find((p) => p.slug === slug);

if (!product) {
  return Astro.redirect('/shop');
}

const breadcrumbs = [
  { label: '쇼핑몰', href: '/shop' },
  { label: product.categoryName, href: `/shop/category/${product.category}` },
  { label: product.name },
];
---

<Layout
  title={`${product.name} - issac.design 쇼핑몰`}
  description={`${product.description} ${product.priceRange} - issac.design에서 제공하는 ${product.categoryName} 제품입니다.`}
>
  <script is:inline>document.body.classList.add('preloader-ready');</script>
  <ScrollProgress />
  <ShopNavbar />
  <Toast />
  <SearchOverlay />

  <main class="product-page" id="main-content">
    <!-- Breadcrumb -->
    <div class="product-page__breadcrumb">
      <Breadcrumb items={breadcrumbs} />
    </div>

    <!-- Product Top Section: Gallery + Info -->
    <section class="product-page__main">
      <div class="product-page__container">
        <div class="product-page__grid">
          <!-- Left: Image Gallery -->
          <div class="product-page__gallery">
            <ImageGallery
              images={product.images}
              productName={product.name}
              materialImages={product.materialImages}
              lightingImages={product.lightingImages}
            />
          </div>

          <!-- Right: Product Info + Configurator -->
          <div class="product-page__info">
            <ProductDetail product={product} />

            <!-- Product Configurator (견적 상품만 표시) -->
            {!product.isFixedPrice && product.options && (
              <div class="product-page__configurator">
                <ProductConfigurator product={product} />
              </div>
            )}

            <!-- Action Button (견적 상품에만 표시; 고정가 결제 버튼은 ProductDetail 내부에 위치) -->
            {!product.isFixedPrice && (
              <div class="product-page__action">
                <AddToQuoteButton product={product} />
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- Production Timeline -->
    {product.productionSteps && product.productionSteps.length > 0 && (
      <section class="product-page__timeline">
        <div class="product-page__container">
          <ProductionTimeline steps={product.productionSteps} />
        </div>
      </section>
    )}

    <!-- Installation Gallery (Before/After) -->
    {product.installationGallery && product.installationGallery.length > 0 && (
      <section class="product-page__installation">
        <div class="product-page__container">
          <InstallationGallery gallery={product.installationGallery} />
        </div>
      </section>
    )}

    <!-- Related Products -->
    {product.relatedProducts && (
      <RelatedProducts
        relatedSlugs={product.relatedProducts}
        currentSlug={product.slug}
        category={product.category}
      />
    )}

    <!-- Warranty & Insurance Badges -->
    <WarrantyBadge />

    <!-- Quote CTA (견적 상품에만 표시) -->
    {!product.isFixedPrice && (
    <section class="product-page__cta" id="quote-form">
      <div class="product-page__cta-container">
        <div class="product-page__cta-content">
          <h2 class="product-page__cta-title">{product.name} 견적이 필요하신가요?</h2>
          <p class="product-page__cta-desc">사이즈, 설치 환경에 맞춘 정확한 견적을 무료로 받아보세요.</p>
          <div class="product-page__cta-actions">
            <a href="/shop/quote" class="product-page__cta-btn product-page__cta-btn--primary">
              <span>무료 견적 요청하기</span>
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="/shop/contact" class="product-page__cta-btn product-page__cta-btn--secondary">
              <span>고객센터 문의</span>
            </a>
          </div>
        </div>
      </div>
    </section>
    )}
  </main>

  <QuoteCartBadge />
  <ShopFooter />
  <ShopAnimations />
</Layout>

<style>
  .product-page {
    position: relative;
    width: 100%;
    min-height: 100vh;
    background: var(--background);
    padding-top: var(--header-height);
  }

  .product-page__breadcrumb {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-lg) var(--container-padding) 0;
  }

  .product-page__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  /* Action Button */
  .product-page__action {
    margin-top: var(--space-xl);
  }

  /* Main Product Section */
  .product-page__main {
    padding: var(--space-xl) 0 var(--space-3xl);
  }

  .product-page__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .product-page__gallery {
    position: sticky;
    top: calc(var(--header-height) + var(--space-lg));
  }

  .product-page__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .product-page__configurator {
    border-top: 1px solid var(--border);
    padding-top: var(--space-2xl);
  }

  /* Timeline Section */
  .product-page__timeline {
    padding: var(--space-4xl) 0;
    background: var(--surface);
    border-top: 1px solid var(--border);
  }

  /* Installation Gallery Section */
  .product-page__installation {
    padding: var(--space-4xl) 0;
    border-top: 1px solid var(--border);
  }

  /* CTA Section */
  .product-page__cta {
    position: relative;
    width: 100%;
    padding: var(--space-4xl) 0;
    background: var(--surface);
    border-top: 1px solid var(--border);
  }

  .product-page__cta-container {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .product-page__cta-content {
    text-align: center;
  }

  .product-page__cta-title {
    font-size: var(--font-size-2xl);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-md);
  }

  .product-page__cta-desc {
    font-size: var(--font-size-base);
    color: var(--text-secondary);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-xl);
  }

  .product-page__cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .product-page__cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-xl);
    font-size: var(--font-size-sm);
    font-weight: 600;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .product-page__cta-btn--primary {
    background: var(--primary);
    color: var(--text-primary);
  }

  .product-page__cta-btn--primary:hover {
    background: var(--primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(26, 77, 46, 0.3);
  }

  .product-page__cta-btn--secondary {
    background: none;
    border: 1px solid var(--border);
    color: var(--text-secondary);
  }

  .product-page__cta-btn--secondary:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  .product-page__cta-btn:active {
    transform: translateY(0);
  }

  /* Responsive */
  @media (max-width: 1023px) {
    .product-page__grid {
      grid-template-columns: 1fr;
      gap: var(--space-3xl);
    }

    .product-page__gallery {
      position: relative;
      top: 0;
    }
  }

  @media (max-width: 719px) {
    .product-page {
      padding-top: var(--header-height-mobile);
    }

    .product-page__main {
      padding: var(--space-lg) 0 var(--space-3xl);
    }

    .product-page__cta,
    .product-page__timeline {
      padding: var(--space-3xl) 0;
    }

    .product-page__cta-title {
      font-size: var(--font-size-xl);
    }

    .product-page__cta-desc {
      font-size: var(--font-size-sm);
    }

    .product-page__cta-actions {
      flex-direction: column;
    }

    .product-page__cta-btn {
      width: 100%;
    }
  }
</style>
