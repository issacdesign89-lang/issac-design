---
/**
 * Contact Page
 * Modern customer service center with contact methods, FAQ, quote form, and location
 */

import Layout from '../../layouts/Layout.astro';
import ShopNavbar from '../../components/shop/ShopNavbar.astro';
import Breadcrumb from '../../components/shop/Breadcrumb.astro';
import ShopFooter from '../../components/shop/ShopFooter.astro';
import Toast from '../../components/shop/Toast.astro';

const kakaoJsKey = import.meta.env.PUBLIC_KAKAO_JS_KEY;

const breadcrumbs = [
  { label: '쇼핑몰', href: '/shop' },
  { label: '고객센터' },
];

const faqs = [
  {
    question: '주문 후 제작 기간은 얼마나 걸리나요?',
    answer: '제품 종류와 사양에 따라 다르지만, 일반적으로 LED 채널간판은 7~10일, 네온사인은 5~7일, 실사출력물은 2~3일 정도 소요됩니다. 대형 프로젝트나 특수 사양의 경우 별도 협의가 필요합니다.',
  },
  {
    question: '시안(디자인) 수정은 몇 번까지 가능한가요?',
    answer: '기본 2회 수정이 포함되어 있으며, 추가 수정이 필요한 경우 별도 비용이 발생할 수 있습니다. 초기 상담 시 원하는 디자인 방향을 상세히 알려주시면 수정 횟수를 줄일 수 있습니다.',
  },
  {
    question: '설치 비용은 별도인가요?',
    answer: '네, 설치 비용은 설치 환경(층수, 크레인 필요 여부 등)에 따라 별도로 산정됩니다. 견적 요청 시 설치 장소 정보를 함께 보내주시면 설치비를 포함한 총 견적을 안내드립니다.',
  },
  {
    question: 'A/S 및 보증 기간은 어떻게 되나요?',
    answer: 'LED 제품은 2년, 기타 제품은 1년의 무상 보증 기간을 제공합니다. 보증 기간 이후에도 합리적인 비용으로 수리 및 유지보수 서비스를 제공합니다.',
  },
  {
    question: '현장 방문 상담도 가능한가요?',
    answer: '네, 서울/경기 지역은 무료 현장 방문 상담이 가능합니다. 그 외 지역은 상담 후 방문 여부를 협의합니다. 전화 또는 카카오톡으로 방문 일정을 예약해주세요.',
  },
];
---

<Layout
  title="고객센터 - issac.design 쇼핑몰"
  description="issac.design 고객센터. 전화, 카카오톡, 이메일로 언제든 문의하세요. 무료 견적 상담 가능."
>
  <script is:inline>document.body.classList.add('preloader-ready');</script>
  <ShopNavbar />
  <Toast />

  <main class="contact-page">
    <!-- Breadcrumb -->
    <div class="contact-page__breadcrumb">
      <Breadcrumb items={breadcrumbs} />
    </div>

    <!-- Hero Section -->
    <section class="contact-hero">
      <div class="contact-hero__bg"></div>
      <div class="contact-hero__container">
        <span class="contact-hero__label">Contact Us</span>
        <h1 class="contact-hero__title">무엇을 도와드릴까요?</h1>
        <p class="contact-hero__subtitle">간판 제작부터 설치까지, 궁금한 점은 언제든 편하게 문의하세요.</p>
      </div>
    </section>

    <!-- Contact Methods -->
    <section class="contact-methods">
      <div class="contact-methods__container">
        <div class="contact-methods__grid">
          <!-- Phone -->
          <a href="tel:02-1234-5678" class="contact-methods__card">
            <div class="contact-methods__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
              </svg>
            </div>
            <div class="contact-methods__text">
              <h3 class="contact-methods__card-title">전화 문의</h3>
              <p class="contact-methods__card-value">02-1234-5678</p>
              <p class="contact-methods__card-note">평일 09:00 ~ 18:00</p>
            </div>
            <span class="contact-methods__arrow">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 4l4 4-4 4"/>
              </svg>
            </span>
          </a>

          <!-- KakaoTalk -->
          <a href="https://pf.kakao.com/issac_design" target="_blank" rel="noopener noreferrer" class="contact-methods__card">
            <div class="contact-methods__icon contact-methods__icon--kakao">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
              </svg>
            </div>
            <div class="contact-methods__text">
              <h3 class="contact-methods__card-title">카카오톡 상담</h3>
              <p class="contact-methods__card-value">issac_design</p>
              <p class="contact-methods__card-note">24시간 접수 가능</p>
            </div>
            <span class="contact-methods__arrow">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 4l4 4-4 4"/>
              </svg>
            </span>
          </a>

          <!-- Email -->
          <a href="mailto:info@issac.design" class="contact-methods__card">
            <div class="contact-methods__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="M22 7l-10 7L2 7"/>
              </svg>
            </div>
            <div class="contact-methods__text">
              <h3 class="contact-methods__card-title">이메일 문의</h3>
              <p class="contact-methods__card-value">info@issac.design</p>
              <p class="contact-methods__card-note">24시간 이내 회신</p>
            </div>
            <span class="contact-methods__arrow">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 4l4 4-4 4"/>
              </svg>
            </span>
          </a>
        </div>
      </div>
    </section>

    <!-- Info Cards Section -->
    <section class="contact-main">
      <div class="contact-main__container">
        <div class="contact-main__grid">
          <!-- Business Hours -->
          <div class="contact-info-card">
            <div class="contact-info-card__header">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 6v6l4 2"/>
              </svg>
              <h2 class="contact-info-card__title">영업시간</h2>
            </div>
            <div class="contact-info-card__body">
              <div class="hours-row">
                <span class="hours-row__day">평일</span>
                <span class="hours-row__time">09:00 ~ 18:00</span>
              </div>
              <div class="hours-row">
                <span class="hours-row__day">토요일</span>
                <span class="hours-row__time">10:00 ~ 15:00</span>
              </div>
              <div class="hours-row hours-row--closed">
                <span class="hours-row__day">일요일 / 공휴일</span>
                <span class="hours-row__time">휴무</span>
              </div>
            </div>
          </div>

          <!-- Location -->
          <div class="contact-info-card">
            <div class="contact-info-card__header">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <h2 class="contact-info-card__title">오시는 길</h2>
            </div>
            <div class="contact-info-card__body">
              <p class="contact-info-card__address">서울특별시 강남구 역삼동 123-45</p>
              <p class="contact-info-card__desc">역삼역 3번 출구에서 도보 5분</p>
            </div>
          </div>

          <!-- Quick Links -->
          <div class="contact-info-card">
            <div class="contact-info-card__header">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z"/>
                <path d="M13 2v7h7"/>
              </svg>
              <h2 class="contact-info-card__title">빠른 링크</h2>
            </div>
            <div class="contact-info-card__body">
              <a href="/shop" class="quick-link">
                <span>제품 둘러보기</span>
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4l4 4-4 4"/></svg>
              </a>
              <a href="/shop/about" class="quick-link">
                <span>회사 소개</span>
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4l4 4-4 4"/></svg>
              </a>
              <a href="/shop/faq" class="quick-link">
                <span>자주 묻는 질문</span>
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4l4 4-4 4"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Map Section -->
    <section class="contact-map">
      <div class="contact-map__container">
        <div class="contact-map__header">
          <span class="contact-map__label">Location</span>
          <h2 class="contact-map__title">오시는 길</h2>
          <p class="contact-map__address">서울특별시 강남구 역삼동 123-45 &middot; 역삼역 3번 출구 도보 5분</p>
        </div>
        <div class="contact-map__wrapper">
          <div id="kakao-map" class="contact-map__embed"></div>
          <div class="contact-map__overlay">
            <a
              href="https://map.kakao.com/link/map/issac.design,37.5012,127.0396"
              target="_blank"
              rel="noopener noreferrer"
              class="contact-map__link"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              카카오맵에서 보기
            </a>
            <a
              href="https://map.kakao.com/link/to/issac.design,37.5012,127.0396"
              target="_blank"
              rel="noopener noreferrer"
              class="contact-map__link contact-map__link--navi"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="3 11 22 2 13 21 11 13 3 11"/>
              </svg>
              길찾기
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="contact-cta">
      <div class="contact-cta__container">
        <div class="contact-cta__content">
          <h2 class="contact-cta__title">견적이 필요하신가요?</h2>
          <p class="contact-cta__desc">간판 제작 견적을 무료로 받아보세요. 현장 사진과 요구사항을 보내주시면 빠르게 안내드립니다.</p>
          <a href="/shop/quote" class="contact-cta__button">
            <span>무료 견적 요청하기</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="contact-faq">
      <div class="contact-faq__container">
        <div class="contact-faq__header">
          <span class="contact-faq__label">FAQ</span>
          <h2 class="contact-faq__title">자주 묻는 질문</h2>
        </div>
        <div class="contact-faq__list">
          {faqs.map((faq, index) => (
            <details class="contact-faq__item" data-faq-item>
              <summary class="contact-faq__question">
                <span class="contact-faq__q-text">{faq.question}</span>
                <span class="contact-faq__toggle">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 6l4 4 4-4"/>
                  </svg>
                </span>
              </summary>
              <div class="contact-faq__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>
        <div class="contact-faq__more">
          <p>찾으시는 답변이 없으신가요?</p>
          <a href="/shop/faq" class="contact-faq__more-link">전체 FAQ 보기 →</a>
        </div>
      </div>
    </section>
  </main>

  <ShopFooter />
</Layout>

<style>
  .contact-page {
    position: relative;
    width: 100%;
    min-height: 100vh;
    background: var(--background);
  }

  .contact-page__breadcrumb {
    padding-top: var(--header-height);
  }

  /* ===== Hero ===== */
  .contact-hero {
    position: relative;
    width: 100%;
    padding: var(--space-3xl) 0 var(--space-2xl);
    text-align: center;
    overflow: hidden;
  }

  .contact-hero__bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(26, 77, 46, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .contact-hero__container {
    position: relative;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .contact-hero__label {
    display: inline-block;
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--primary-light);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    margin-bottom: var(--space-md);
    padding: var(--space-xs) var(--space-md);
    background: rgba(26, 77, 46, 0.08);
    border-radius: var(--radius-full);
  }

  .contact-hero__title {
    font-size: var(--font-size-4xl);
    font-weight: 700;
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
    color: var(--text-primary);
    margin-bottom: var(--space-md);
  }

  .contact-hero__subtitle {
    font-size: var(--font-size-lg);
    color: var(--text-secondary);
    line-height: var(--line-height-relaxed);
    max-width: 480px;
    margin: 0 auto;
  }

  /* ===== Contact Methods ===== */
  .contact-methods {
    position: relative;
    width: 100%;
    padding-bottom: var(--space-3xl);
  }

  .contact-methods__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .contact-methods__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .contact-methods__card {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-xl) var(--space-xl);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    transition: all var(--transition-base);
    cursor: pointer;
    text-decoration: none;
    color: inherit;
  }

  .contact-methods__card:hover {
    border-color: var(--primary);
    box-shadow: 0 4px 20px rgba(26, 77, 46, 0.08);
    transform: translateY(-2px);
  }

  .contact-methods__card:hover .contact-methods__arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .contact-methods__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: rgba(26, 77, 46, 0.08);
    border-radius: var(--radius-md);
    color: var(--primary-light);
    flex-shrink: 0;
  }

  .contact-methods__text {
    flex: 1;
    min-width: 0;
  }

  .contact-methods__card-title {
    font-size: var(--font-size-xs);
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
    margin-bottom: 2px;
  }

  .contact-methods__card-value {
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 2px;
  }

  .contact-methods__card-note {
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
  }

  .contact-methods__arrow {
    flex-shrink: 0;
    color: var(--primary-light);
    opacity: 0;
    transform: translateX(-4px);
    transition: all var(--transition-base);
  }

  /* ===== Info Cards Section ===== */
  .contact-main {
    position: relative;
    width: 100%;
    padding: var(--space-3xl) 0;
    background: var(--surface);
    border-top: 1px solid var(--border);
  }

  .contact-main__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .contact-main__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .contact-info-card {
    padding: var(--space-xl);
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .contact-info-card__header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
    color: var(--text-primary);
  }

  .contact-info-card__header svg {
    color: var(--primary-light);
    flex-shrink: 0;
  }

  .contact-info-card__title {
    font-size: var(--font-size-base);
    font-weight: 600;
  }

  .contact-info-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  /* Hours */
  .hours-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--border);
  }

  .hours-row:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  .hours-row__day {
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--text-primary);
  }

  .hours-row__time {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
  }

  .hours-row--closed .hours-row__time {
    color: var(--error);
    font-weight: 500;
  }

  /* Location */
  .contact-info-card__address {
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--text-primary);
    line-height: var(--line-height-relaxed);
  }

  .contact-info-card__desc {
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
  }

  /* Quick Links */
  .quick-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) 0;
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border);
    transition: color var(--transition-base);
    text-decoration: none;
  }

  .quick-link:last-child {
    border-bottom: none;
  }

  .quick-link:hover {
    color: var(--primary);
  }

  .quick-link svg {
    opacity: 0;
    transform: translateX(-4px);
    transition: all var(--transition-base);
  }

  .quick-link:hover svg {
    opacity: 1;
    transform: translateX(0);
  }

  /* ===== Map Section ===== */
  .contact-map {
    position: relative;
    width: 100%;
    padding: var(--space-4xl) 0;
    border-top: 1px solid var(--border);
  }

  .contact-map__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .contact-map__header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

