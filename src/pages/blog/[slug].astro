---
export const prerender = true;

import ShopLayout from '../../components/shop/ShopLayout.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter(post => !post.id.startsWith('_'))
    .map(post => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<ShopLayout
  title={`${post.data.title} - issac.design 블로그`}
  description={post.data.description || post.data.title}
  breadcrumbs={[
    { label: '블로그', href: '/blog' },
    { label: post.data.title },
  ]}
>
  <main class="blog-post-page">
    <article class="post-article">
      <header class="post-header">
        <div class="container">
          <a href="/blog" class="back-link">&larr; 블로그 목록</a>
          {post.data.tags && (
            <div class="post-tags">
              {post.data.tags.map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
          <h1>{post.data.title}</h1>
          <time datetime={post.data.date}>
            {new Date(post.data.date).toLocaleDateString('ko-KR', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
        </div>
      </header>

      {(post.data.heroImage || post.data.thumbnail) && (
        <div class="post-hero-image container">
          <Image
            src={post.data.heroImage?.src || post.data.thumbnail || ''}
            alt={post.data.heroImage?.alt || post.data.title}
            loading="eager"
            decoding="async"
            fetchpriority="high"
            width={800}
            height={450}
            format="webp"
            quality={85}
          />
          {post.data.heroImage?.credit && (
            <p class="image-credit">
              {post.data.heroImage.creditUrl ? (
                <a href={post.data.heroImage.creditUrl} target="_blank" rel="noopener noreferrer">
                  {post.data.heroImage.credit}
                </a>
              ) : (
                post.data.heroImage.credit
              )}
            </p>
          )}
        </div>
      )}

      <div class="post-body container">
        <Content />
      </div>
    </article>
  </main>
</ShopLayout>

<style>
  .blog-post-page {
    min-height: 100vh;
    background: var(--background);
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Header */
  .post-header {
    padding: 8rem 0 2rem;
  }

  .back-link {
    display: inline-block;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--accent);
    background: rgba(102, 187, 106, 0.1);
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
  }

  .post-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
    margin-bottom: 1rem;
  }

  .post-header time {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  /* Hero Image */
  .post-hero-image {
    margin-bottom: 3rem;
  }

  .post-hero-image img {
    width: 100%;
    border-radius: 12px;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .image-credit {
    text-align: right;
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
  }

  .image-credit a {
    color: var(--text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .image-credit a:hover {
    color: var(--accent);
  }

  /* Post Body - Markdown Content Styling */
  .post-body {
    padding-bottom: 6rem;
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .post-body :global(h1) {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 2.5rem 0 1rem;
  }

  .post-body :global(h2) {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 2rem 0 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .post-body :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 1.5rem 0 0.5rem;
  }

  .post-body :global(p) {
    margin-bottom: 1.25rem;
  }

  .post-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-body :global(a:hover) {
    color: var(--accent-light);
  }

  .post-body :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .post-body :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--primary);
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    background: var(--surface);
    border-radius: 0 8px 8px 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .post-body :global(code) {
    font-size: 0.9em;
    background: var(--surface);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    color: var(--accent);
  }

  .post-body :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    margin: 1.5rem 0;
    overflow-x: auto;
  }

  .post-body :global(pre code) {
    background: none;
    padding: 0;
    color: var(--text-secondary);
  }

  .post-body :global(img) {
    max-width: 100%;
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }

  @media (max-width: 768px) {
    .post-header {
      padding: 6rem 0 1.5rem;
    }

    .post-body {
      font-size: 1rem;
    }
  }
</style>
