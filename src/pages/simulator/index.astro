---
export const prerender = true;

/**
 * 3D 간판 시뮬레이터 페이지
 * PNG 알파 채널 기반 3D 입체 간판 생성 시뮬레이터
 */
import PngTo3DExtruder from '../../components/simulator/PngTo3DExtruder';
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>3D 간판 시뮬레이터</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html, body {
        width: 100%;
        height: 100%;
        overflow: hidden;
      }
      @media (max-width: 768px) {
        html, body {
          overflow: auto;
          overflow-x: hidden;
        }
      }
    </style>
  </head>
  <body>
    <PngTo3DExtruder client:only="react" />
  </body>
</html>
