// --- Category name helper ---
function getCategoryName(id: string): string {
  const map: Record<string, string> = {
    'banner-stand': '배너거치대', 'banner-print': '배너출력물', 'banner-cloth': '현수막',
    'banner-cloth-bulk': '대량현수막', 'wind-banner': '윈드배너', 'sign-board': '입간판',
    'sign-board-print': '입간판출력물', 'print-output': '실사출력',
    'scroll-blind': '족자봉·롤블라인드', 'custom-payment': '고객맞춤결제',
  };
  return map[id] || id;
}

// --- Supabase fetch (primary) ---
let product: any = null;

try {
  const { data, error } = await supabase
    .from('products')
    .select('*')
    .eq('slug', slug as string)
    .eq('is_visible', true)
    .single();

  if (!error && data) {
    const opts = (data.options as any) || {};
    product = {
      name: data.name,
      category: { id: data.category_id || '', name: getCategoryName(data.category_id || '') },
      subcategory: opts.subcategory || '',
      basePrice: Number(opts.base_price) || 0,
      thumbnail: data.thumbnail || 'https://placehold.co/800x800/f5f5f5/999?text=No+Image',
      images: Array.isArray(data.images) ? data.images : [],
      description: data.description || '',
      specs: typeof data.specs === 'object' && data.specs !== null && !Array.isArray(data.specs)
        ? Object.entries(data.specs).map(([k, v]) => ({ label: k, value: v as string }))
        : [],
      options: Array.isArray(opts.option_groups) ? opts.option_groups : [],
      deliveryOptions: Array.isArray(opts.delivery_options) ? opts.delivery_options : [],
      deadlines: { courier: opts.deadline_courier || '', pickup: opts.deadline_pickup || '' },
    };
  }
} catch (e) {
  console.error('[banner/product] Supabase fetch failed:', e);
}

