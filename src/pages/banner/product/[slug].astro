---

<Layout title={`${product.name} - issac.design 배너`} description={product.description}>

<style is:global>
  /* ===== Product Detail ===== */
  .pd-breadcrumb {
    padding: 14px 0;
    font-size: 13px;
    color: #999;
    text-align: right;
    border-bottom: 1px solid #e0e0e0;
  }
  .pd-breadcrumb a { color: #666; }
  .pd-breadcrumb a:hover { color: #1A4D2E; text-decoration: underline; }
  .pd-breadcrumb span { color: #222; font-weight: 600; }

  .pd-layout {
    display: grid;
    grid-template-columns: 1fr 1fr 280px;
    gap: 0;
    padding: 32px 0 64px;
    align-items: start;
  }

  /* Left: Image */
  .pd-image {
    padding-right: 32px;
  }
  .pd-image-main {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    background: #f5f5f5;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
  }
  .pd-image-thumbs {
    display: flex;
    gap: 8px;
    margin-top: 12px;
  }
  .pd-image-thumb {
    width: 72px;
    height: 72px;
    object-fit: cover;
    border: 2px solid #e0e0e0;
    border-radius: 4px;
    cursor: pointer;
  }
  .pd-image-thumb.active { border-color: #1A4D2E; }

  /* Center: Options */
  .pd-options {
    padding: 0 24px;
    border-left: 1px solid #eee;
  }
  .pd-title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid #eee;
  }
  .pd-item-label { font-size: 14px; color: #666; font-weight: 600; }
  .pd-item-value { font-size: 15px; font-weight: 700; color: #222; }
  .pd-guide-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 6px 14px;
    font-size: 12px;
    font-weight: 600;
    color: #555;
    border: 1px solid #ddd;
    border-radius: 4px;
    background: #fff;
    cursor: pointer;
  }
  .pd-guide-btn:hover { border-color: #1A4D2E; color: #1A4D2E; }

  .pd-option-group {
    margin-bottom: 16px;
  }
  .pd-option-label {
    display: block;
    font-size: 13px;
    font-weight: 700;
    color: #333;
    margin-bottom: 6px;
  }
  .pd-option-select {
    width: 100%;
    padding: 10px 12px;
    font-size: 14px;
    border: 1px solid #ddd;
    border-radius: 4px;
    background: #fff;
    color: #222;
    cursor: pointer;
    font-family: inherit;
    appearance: auto;
  }
  .pd-option-select:focus { border-color: #1A4D2E; outline: none; }

  .pd-qty-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .pd-qty-input {
    width: 60px;
    padding: 8px;
    text-align: center;
    font-size: 14px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-family: inherit;
  }
  .pd-qty-unit { font-size: 14px; color: #555; }

  /* Delivery */
  .pd-delivery {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid #eee;
  }
  .pd-delivery-select {
    width: 70%;
    padding: 10px 12px;
    font-size: 14px;
    border: 1px solid #ddd;
    border-radius: 4px;
    background: #fff;
    font-family: inherit;
    appearance: auto;
  }
  .pd-delivery-info {
    font-size: 12px;
    color: #e8590c;
    margin-top: 4px;
  }

  /* File & Note */
  .pd-file-row {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid #eee;
  }
  .pd-file-btns {
    display: flex;
    gap: 8px;
    margin-top: 6px;
  }
  .pd-file-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 600;
    border: 1px solid #1A4D2E;
    color: #1A4D2E;
    border-radius: 4px;
    background: #fff;
    cursor: pointer;
  }
  .pd-file-btn:hover { background: #f0f8f3; }

  .pd-note {
