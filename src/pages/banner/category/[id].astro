// --- Supabase product fetching ---
let dbProducts: any[] = [];
try {
  const CATEGORY_GROUP: Record<string, string[]> = {
    'banner-cloth': ['banner-cloth', 'banner-cloth-bulk'],
    'sign-board': ['sign-board', 'sign-board-print'],
  };
  const categoryIds = CATEGORY_GROUP[id as string] || [id as string];
  const { data } = await supabase
    .from('products')
    .select('*')
    .in('category_id', categoryIds)
    .eq('is_visible', true)
    .order('created_at', { ascending: false });
  if (data) dbProducts = data;
} catch (e) {
  console.error('[banner/category] Supabase fetch failed:', e);
}

// Use Supabase data if available, otherwise fall back to hardcoded
const products = dbProducts.length > 0 ? dbProducts.map((p: any) => ({
  name: p.name,
  slug: p.slug,
  price: p.price || '문의',
  thumbnail: p.thumbnail || 'https://picsum.photos/seed/default/400/400.webp',
  description: p.description || '',
  subcategory: (p.options as any)?.subcategory || '',
})) : (ALL_BANNER_PRODUCTS[id as string] || []);

const currentYear = new Date().getFullYear();
