    padding: 6px 0 6px 12px;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    border-radius: 4px;
  }
  .sb-item:hover {
    color: #1A4D2E;
    background: #f5f9f7;
  }
  .sb-item.active {
    color: #1A4D2E;
    font-weight: 700;
    background: #edf5f0;
  }

  /* --- Main Content --- */
  .cp-main {
    flex: 1;
    min-width: 0;
    padding: 24px 0 64px 32px;
  }

  .cp-main-header {
    margin-bottom: 24px;
  }
  .cp-main-header h1 {
    font-size: 1.4rem;
    font-weight: 800;
    color: #222;
    letter-spacing: -0.02em;
  }
  .cp-main-header p {
    font-size: 14px;
    color: #999;
    margin-top: 4px;
  }

  /* ===== Product Grid ===== */
  .cp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .cp-card {
    display: block;
    transition: transform 0.15s;
  }
  .cp-card:hover { transform: translateY(-4px); }
  .cp-card-img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    background: #f5f5f5;
    border-radius: 6px;
    margin-bottom: 12px;
  }
  .cp-card-name {
    font-size: 15px;
    font-weight: 700;
    color: #222;
    margin-bottom: 4px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
  }
  .cp-card-price {
    font-size: 16px;
    font-weight: 800;
    color: #e8590c;
    white-space: nowrap;
  }
  .cp-card-desc {
    font-size: 12px;
    color: #999;
    line-height: 1.5;
    margin-top: 4px;
  }

  .cp-empty {
    text-align: center;
    padding: 80px 0;
    color: #999;
  }
  .cp-empty h2 { font-size: 1.2rem; color: #666; margin-bottom: 8px; }
  .cp-empty a {
    display: inline-block;
    margin-top: 16px;
    padding: 10px 24px;
    background: #1A4D2E;
    color: #fff;
    font-weight: 700;
    font-size: 14px;
    border-radius: 6px;
  }

  /* ===== Footer ===== */
  .cp-footer {
    background: #1a1a1a;
    color: #777;
    padding: 32px 0;
    font-size: 12px;
    text-align: center;
  }
  .cp-footer a { color: #aaa; }

  /* ===== Responsive ===== */
  @media (max-width: 960px) {
    .cp-grid { grid-template-columns: repeat(2, 1fr); }
    .cp-sidebar { width: 180px; min-width: 180px; }
    .cp-tab { padding: 12px 20px; font-size: 15px; }
  }
  @media (max-width: 768px) {
    .cp-layout {
      flex-direction: column;
    }
    .cp-sidebar {
      width: 100%;
      min-width: 100%;
      border-right: none;
      border-bottom: 1px solid #e8e8e8;
      padding: 16px 0;
      display: flex;
      gap: 24px;
      overflow-x: auto;
    }
    .cp-sb-group {
      margin-bottom: 0;
      min-width: max-content;
    }
    .cp-sb-title {
      border-bottom: none;
      padding-bottom: 4px;
      font-size: 14px;
    }
    .sb-item {
      padding: 4px 10px;
      font-size: 13px;
      white-space: nowrap;
    }
    .cp-main {
      padding: 20px 0 48px 0;
    }
    .cp-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .cp-tab { padding: 10px 16px; font-size: 14px; }
  }
  @media (max-width: 480px) {
    .cp-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .cp-tab { padding: 10px 12px; font-size: 13px; }
  }
</style>

<div class="hl">
  <!-- Shared Header + Hero -->
  <BannerHeader contactInfo={contactInfo} services={services} megaMenuData={megaMenuData} />

  <!-- Breadcrumb -->
  <div class="wrap">
    <div class="cp-breadcrumb">
      <a href="/banner">HOME</a> &gt; <span>{current.name}</span>
    </div>
  </div>

  <!-- Category Tabs -->
  <div class="wrap">
    <nav class="cp-tabs">
      {sectionCategoryIds.map((catId) => (
        <a
          href={`/banner/category/${catId}`}
          class={`cp-tab${catId === id ? ' active' : ''}`}
        >
          {SECTION_TAB_LABELS[catId] || catId}
        </a>
      ))}
    </nav>
  </div>

  <!-- Sidebar + Product Grid Layout -->
  <div class="wrap">
    <div class="cp-layout">
      <!-- Left Sidebar -->
      <aside class="cp-sidebar">
        {sidebarGroups.map((group) => (
          <div class="cp-sb-group">
            <div class="cp-sb-title">{group.title}</div>
            <ul class="cp-sb-list">
              {group.items.map((item) => (
                <li class="sb-item" data-subcategory={item.label}>{item.label}</li>
              ))}
            </ul>
          </div>
        ))}
      </aside>

      <!-- Main Content -->
      <div class="cp-main">
        <div class="cp-main-header">
          <h1>{current.name}</h1>
          <p>{products.length}개의 제품</p>
        </div>

        {products.length > 0 ? (
          <div class="cp-grid">
            {products.map((p) => (
              <a href={`/banner/product/${p.slug}`} class="cp-card" data-subcategory={p.subcategory || ''}>
                <img src={p.thumbnail} alt={p.name} class="cp-card-img" loading="lazy" />
                <div class="cp-card-name">
                  <span>{p.name}</span>
                  <span class="cp-card-price">{p.price === '문의' ? '가격문의' : p.price}</span>
                </div>
                {p.description && <div class="cp-card-desc">{p.description.slice(0, 50)}</div>}
              </a>
            ))}
          </div>
        ) : (
          <div class="cp-empty">
            <h2>등록된 제품이 없습니다</h2>
            <p>곧 새로운 제품이 추가될 예정입니다.</p>
            <a href="/banner#contact">문의하기</a>
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="cp-footer">
    <div class="wrap">
      <p>&copy; {currentYear} issac.design · 간판 전문 제작·시공 | <a href={`tel:${contactInfo.phone}`}>{contactInfo.phone}</a></p>
    </div>
  </footer>
</div>

<!-- Client-side subcategory filtering -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sidebarItems = document.querySelectorAll<HTMLElement>('.sb-item');
    const productCards = document.querySelectorAll<HTMLElement>('.cp-card');
    const countEl = document.querySelector('.cp-main-header p');

    function filterBySubcategory(sub: string | null) {
      sidebarItems.forEach(i => i.classList.remove('active'));

      if (!sub) {
        productCards.forEach(card => { (card as HTMLElement).style.display = ''; });
        if (countEl) countEl.textContent = `${productCards.length}개의 제품`;
        return;
      }

      sidebarItems.forEach(i => {
        if (i.dataset.subcategory === sub) i.classList.add('active');
      });

      let visibleCount = 0;
      productCards.forEach(card => {
        const match = card.dataset.subcategory === sub;
        (card as HTMLElement).style.display = match ? '' : 'none';
        if (match) visibleCount++;
      });
      if (countEl) countEl.textContent = `${visibleCount}개의 제품`;
    }

    // ?sub= 쿼리 파라미터로 페이지 로드 시 필터 적용
    const urlSub = new URL(window.location.href).searchParams.get('sub');
    if (urlSub) filterBySubcategory(urlSub);

    sidebarItems.forEach(item => {
      item.addEventListener('click', () => {
        const sub = item.dataset.subcategory;
        const isActive = item.classList.contains('active');
        filterBySubcategory(isActive ? null : (sub || null));
      });
    });
  });
</script>

</Layout>
