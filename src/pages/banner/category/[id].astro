---
/**
 * Category Product List Page
 * /banner/category/[id] — 카테고리별 제품 리스트
 * BannerHeader 공통 컴포넌트 사용 (메뉴 + 히어로 동일)
 */
import Layout from '../../../layouts/Layout.astro';
import BannerHeader from '../../../components/banner/BannerHeader.astro';
import { supabase } from '../../../lib/supabase';
import { APP_VERSION } from '../../../version';

const { id } = Astro.params;

// --- Shared data for BannerHeader ---
const FALLBACK_SERVICES = [
  { icon: 'banner', title: '배너·거치대', desc: '실내외 배너 거치대 전문 제작·판매' },
  { icon: 'banner', title: '현수막', desc: '일반·장폭·솔벤·라텍스 현수막 제작' },
  { icon: 'banner', title: '윈드배너', desc: 'F형·S형·H형 윈드배너 거치대·출력' },
  { icon: 'banner', title: '입간판', desc: 'A형·물통·사인스탠드 입간판 제작' },
  { icon: 'banner', title: '실사출력', desc: '접착·비접착·시트커팅·차량용 출력' },
  { icon: 'banner', title: '족자봉·롤블라인드', desc: '족자봉, 롤블라인드 제작·판매' },
];

const FALLBACK_CONTACT = {
  company: 'issac.design',
  phone: '010-1234-5678',
  hours: '평일 09:00~18:00 (토 09:00~15:00)',
  address: '서울시 강남구 테헤란로 123',
  email: 'contact@issac.design',
};

let services = FALLBACK_SERVICES;
let contactInfo = FALLBACK_CONTACT;
// 배너 전용 카테고리 (하드코딩)
const categories = [
  { id: 'banner-stand', name: '배너거치대', order_index: 1 },
  { id: 'banner-cloth', name: '현수막', order_index: 2 },
  { id: 'wind-banner', name: '윈드배너', order_index: 3 },
  { id: 'sign-board', name: '입간판', order_index: 4 },
  { id: 'print-output', name: '실사출력', order_index: 5 },
  { id: 'scroll-blind', name: '족자봉·롤블라인드', order_index: 6 },
  { id: 'custom-payment', name: '고객맞춤결제', order_index: 7 },
];

try {
  const { data } = await supabase.from('site_config').select('key, value').eq('category', 'contact');
  if (data?.length) {
    const m: Record<string, string> = {};
    data.forEach((c: any) => { m[c.key] = c.value; });
    contactInfo = {
      company: m.company_name || FALLBACK_CONTACT.company,
      phone: m.phone || FALLBACK_CONTACT.phone,
      hours: m.business_hours || FALLBACK_CONTACT.hours,
      address: m.address || FALLBACK_CONTACT.address,
      email: m.email || FALLBACK_CONTACT.email,
    };
  }
} catch {}

// Current category
const current = categories.find(c => c.id === id);
if (!current) return Astro.redirect('/banner');

// 배너 임시 상품 데이터
const ALL_BANNER_PRODUCTS: Record<string, any[]> = {
  'banner-stand': [
    { name: '실외 배너거치대 (대형)', slug: 'banner-stand-outdoor-l', price: '45,000원', thumbnail: 'https://picsum.photos/seed/bstand/400/400.webp', description: '야외 행사·매장 앞 홍보용 대형 거치대' },
  ],
  'banner-cloth': [
    { name: '일반현수막 (맞춤사이즈)', slug: 'banner-cloth-normal', price: '15,000원', thumbnail: 'https://picsum.photos/seed/bcloth/400/400.webp', description: '맞춤 사이즈 일반현수막 제작' },
  ],
  'wind-banner': [
    { name: '윈드배너 F형 (소형)', slug: 'wind-banner-f-s', price: '38,000원', thumbnail: 'https://picsum.photos/seed/bwind/400/400.webp', description: 'F형 소형 윈드배너 + 철판 베이스' },
  ],
  'sign-board': [
    { name: 'A형 입간판', slug: 'sign-board-a', price: '55,000원', thumbnail: 'https://picsum.photos/seed/bsign/400/400.webp', description: '양면 A형 입간판 (포스터 교체 가능)' },
  ],
  'print-output': [
    { name: '실사출력 (접착용)', slug: 'print-output-adhesive', price: '8,000원', thumbnail: 'https://picsum.photos/seed/bprint/400/400.webp', description: '접착용 실사출력 (평당 가격)' },
  ],
  'scroll-blind': [
    { name: '족자봉 (기본형)', slug: 'scroll-basic', price: '12,000원', thumbnail: 'https://picsum.photos/seed/bscroll/400/400.webp', description: '기본형 족자봉 세트' },
  ],
  'custom-payment': [
    { name: '고객맞춤결제', slug: 'custom-payment', price: '문의', thumbnail: 'https://picsum.photos/seed/bcustom/400/400.webp', description: '맞춤 주문 결제' },
  ],
};
const products = ALL_BANNER_PRODUCTS[id as string] || [];

// Subcategory mapping
const SUBCATEGORY_MAP: Record<string, { label: string; href?: string }[]> = {
  '배너거치대': [
    { label: '실외거치대' }, { label: '실내거치대' }, { label: '철제거치대' },
    { label: '자이언트폴' }, { label: '미니배너' }, { label: '특수배너' }, { label: '부속품' },
  ],
  '현수막': [
    { label: '일반현수막' }, { label: '장폭현수막' }, { label: '솔벤현수막' },
    { label: '라텍스현수막' }, { label: '테이블현수막' }, { label: '열전사메쉬' },
    { label: '텐트천' }, { label: '부직포' }, { label: '부속품' },
  ],
  '윈드배너': [
    { label: '윈드배너F형' }, { label: '윈드배너S형' }, { label: '윈드배너H형' }, { label: '부속품' },
  ],
  '입간판': [
    { label: 'A형입간판' }, { label: '물통입간판' }, { label: '사인스탠드' }, { label: '부속품' },
  ],
  '실사출력': [
    { label: '접착용' }, { label: '비접착용' }, { label: '시트커팅' },
    { label: '차량용자석' }, { label: 'POP·보드' }, { label: '등신대' },
  ],
  '족자봉·롤블라인드': [
    { label: '족자봉' }, { label: '롤블라인드' }, { label: '부속품' },
  ],
  '고객맞춤결제': [
    { label: '고객맞춤결제' }, { label: '디자인비결제' }, { label: '배송비결제' },
  ],
};

const megaMenuData = categories.map(cat => ({
  id: cat.id,
  name: cat.name,
  subcategories: SUBCATEGORY_MAP[cat.name] || [{ label: '전체보기' }],
}));

const currentYear = new Date().getFullYear();

export async function getStaticPaths() {
  const ids = ['banner-stand', 'banner-cloth', 'wind-banner', 'sign-board', 'print-output', 'scroll-blind', 'custom-payment'];
  return ids.map(id => ({ params: { id } }));
}
---

<Layout title={`${current.name} - issac.design`} description={`${current.name} 제품 목록 - issac.design 배너 전문`}>

<style is:global>
  /* ===== Category page content ===== */
  .cp-breadcrumb {
    padding: 16px 0;
    border-bottom: 1px solid #e0e0e0;
    font-size: 13px;
    color: #999;
    text-align: right;
  }
  .cp-breadcrumb a { color: #666; }
  .cp-breadcrumb a:hover { color: #1A4D2E; text-decoration: underline; }
  .cp-breadcrumb span { color: #222; font-weight: 600; }

  .cp-header {
    padding: 32px 0 24px;
    border-bottom: 2px solid #222;
  }
  .cp-header h1 {
    font-size: 1.6rem;
    font-weight: 800;
    color: #222;
    letter-spacing: -0.02em;
  }
  .cp-header p {
    font-size: 14px;
    color: #999;
    margin-top: 6px;
  }

  .cp-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    padding: 32px 0 64px;
  }
  .cp-card {
    display: block;
    transition: transform 0.15s;
  }
  .cp-card:hover { transform: translateY(-4px); }
  .cp-card-img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    background: #f5f5f5;
    border-radius: 6px;
    margin-bottom: 12px;
  }
  .cp-card-name {
    font-size: 15px;
    font-weight: 700;
    color: #222;
    margin-bottom: 4px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .cp-card-price {
    font-size: 16px;
    font-weight: 800;
    color: #e8590c;
    white-space: nowrap;
  }
  .cp-card-desc {
    font-size: 12px;
    color: #999;
    line-height: 1.5;
    margin-top: 4px;
  }

  .cp-empty {
    text-align: center;
    padding: 80px 0;
    color: #999;
  }
  .cp-empty h2 { font-size: 1.2rem; color: #666; margin-bottom: 8px; }
  .cp-empty a {
    display: inline-block;
    margin-top: 16px;
    padding: 10px 24px;
    background: #1A4D2E;
    color: #fff;
    font-weight: 700;
    font-size: 14px;
    border-radius: 6px;
  }

  .cp-footer {
    background: #1a1a1a;
    color: #777;
    padding: 32px 0;
    font-size: 12px;
    text-align: center;
  }
  .cp-footer a { color: #aaa; }

  @media (max-width: 960px) {
    .cp-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 768px) {
    .cp-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
  }
  @media (max-width: 480px) {
    .cp-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
  }
</style>

<div class="hl">
  <!-- Shared Header + Hero -->
  <BannerHeader contactInfo={contactInfo} services={services} megaMenuData={megaMenuData} />

  <!-- Breadcrumb -->
  <div class="wrap">
    <div class="cp-breadcrumb">
      <a href="/banner">HOME</a> &gt; <span>{current.name}</span>
    </div>
  </div>

  <!-- Page Header -->
  <div class="wrap">
    <div class="cp-header">
      <h1>{current.name}</h1>
      <p>{products.length}개의 제품</p>
    </div>
  </div>

  <!-- Product Grid -->
  <div class="wrap">
    {products.length > 0 ? (
      <div class="cp-grid">
        {products.map((p) => (
          <a href={`/banner/product/${p.slug}`} class="cp-card">
            <img src={p.thumbnail} alt={p.name} class="cp-card-img" loading="lazy" />
            <div class="cp-card-name">
              <span>{p.name}</span>
              <span class="cp-card-price">{p.price === '문의' ? '가격문의' : p.price}</span>
            </div>
            {p.description && <div class="cp-card-desc">{p.description.slice(0, 50)}</div>}
          </a>
        ))}
      </div>
    ) : (
      <div class="cp-empty">
        <h2>등록된 제품이 없습니다</h2>
        <p>곧 새로운 제품이 추가될 예정입니다.</p>
        <a href="/banner#contact">문의하기</a>
      </div>
    )}
  </div>

  <!-- Footer -->
  <footer class="cp-footer">
    <div class="wrap">
      <p>&copy; {currentYear} issac.design · 간판 전문 제작·시공 | <a href={`tel:${contactInfo.phone}`}>{contactInfo.phone}</a></p>
    </div>
  </footer>
</div>

</Layout>
