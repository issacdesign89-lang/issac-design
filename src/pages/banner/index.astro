---
/**
 * Banner Factory (배너공장)
 * 배너·현수막·윈드배너·입간판·실사출력 전문 사이트
 */
import Layout from '../../layouts/Layout.astro';
import BannerHeader from '../../components/banner/BannerHeader.astro';
import { supabase } from '../../lib/supabase';
import { APP_VERSION } from '../../version';

// --- Data ---
const FALLBACK_SERVICES = [
  { icon: 'banner', title: '배너·거치대', desc: '실내외 배너 거치대 전문 제작·판매' },
  { icon: 'banner', title: '현수막', desc: '일반·장폭·솔벤·라텍스 현수막 제작' },
  { icon: 'banner', title: '윈드배너', desc: 'F형·S형·H형 윈드배너 거치대·출력' },
  { icon: 'banner', title: '입간판', desc: 'A형·물통·사인스탠드 입간판 제작' },
  { icon: 'banner', title: '실사출력', desc: '접착·비접착·시트커팅·차량용 출력' },
  { icon: 'banner', title: '족자봉·롤블라인드', desc: '족자봉, 롤블라인드 제작·판매' },
];

const FALLBACK_CONTACT = {
  company: 'issac.design',
  phone: '010-1234-5678',
  hours: '평일 09:00~18:00 (토 09:00~15:00)',
  address: '서울시 강남구 테헤란로 123',
  email: 'contact@issac.design',
};

let services = FALLBACK_SERVICES;
let contactInfo = FALLBACK_CONTACT;
let products: any[] = [];
let portfolio: any[] = [];
// 배너 전용 카테고리 (하드코딩)
const categories = [
  { id: 'banner-stand', name: '배너거치대', order_index: 1 },
  { id: 'banner-print', name: '배너출력물', order_index: 2 },
  { id: 'banner-cloth', name: '현수막', order_index: 3 },
  { id: 'banner-cloth-bulk', name: '대량현수막', order_index: 3.5 },
  { id: 'wind-banner', name: '윈드배너', order_index: 4 },
  { id: 'sign-board', name: '입간판', order_index: 5 },
  { id: 'sign-board-print', name: '입간판출력물', order_index: 5.5 },
  { id: 'print-output', name: '실사출력', order_index: 6 },
  { id: 'scroll-blind', name: '족자봉·롤블라인드', order_index: 7 },
  { id: 'custom-payment', name: '고객맞춤결제', order_index: 8 },
];

// Supabase에서 배너 상품 동적 조회
const FALLBACK_PRODUCTS = [
  { name: '실외 배너거치대 (대형)', slug: 'banner-stand-outdoor-l', price: '45,000원', thumbnail: 'https://picsum.photos/seed/bstand/400/400.webp', category_id: 'banner-stand' },
  { name: '배너출력물 (단면)', slug: 'banner-print-standard', price: '12,000원', thumbnail: 'https://picsum.photos/seed/bprint-out/400/400.webp', category_id: 'banner-print' },
  { name: '일반현수막 (맞춤사이즈)', slug: 'banner-cloth-normal', price: '15,000원', thumbnail: 'https://picsum.photos/seed/bcloth/400/400.webp', category_id: 'banner-cloth' },
  { name: '윈드배너 F형 (소형)', slug: 'wind-banner-f-s', price: '38,000원', thumbnail: 'https://picsum.photos/seed/bwind/400/400.webp', category_id: 'wind-banner' },
  { name: 'A형 입간판', slug: 'sign-board-a', price: '55,000원', thumbnail: 'https://picsum.photos/seed/bsign/400/400.webp', category_id: 'sign-board' },
  { name: '실사출력 (접착용)', slug: 'print-output-adhesive', price: '8,000원', thumbnail: 'https://picsum.photos/seed/bprint/400/400.webp', category_id: 'print-output' },
  { name: '족자봉 (기본형)', slug: 'scroll-basic', price: '12,000원', thumbnail: 'https://picsum.photos/seed/bscroll/400/400.webp', category_id: 'scroll-blind' },
  { name: '고객맞춤결제', slug: 'custom-payment', price: '문의', thumbnail: 'https://picsum.photos/seed/bcustom/400/400.webp', category_id: 'custom-payment' },
  { name: 'A형입간판 출력물', slug: 'sign-board-a-print', price: '12,000원', thumbnail: 'https://picsum.photos/seed/sbprint-a/400/400.webp', description: 'A형입간판 전용 포스터 출력물', category_id: 'sign-board-print' },
];

try {
  const bannerCategoryIds = categories.map(c => c.id);
  const { data } = await supabase
    .from('products')
    .select('name, slug, price, thumbnail, category_id')
    .in('category_id', bannerCategoryIds)
    .eq('is_visible', true)
    .order('created_at', { ascending: false });
  if (data?.length) {
    products = data.map((p: any) => ({
      name: p.name,
      slug: p.slug,
      price: p.price || '문의',
      thumbnail: p.thumbnail || '',
      category_id: p.category_id,
    }));
  }
} catch {}

// DB 결과 없으면 하드코딩 fallback
if (!products.length) {
  products = FALLBACK_PRODUCTS;
}

try {
  const { data } = await supabase.from('portfolio_items').select('*').eq('is_visible', true).order('order_index').limit(6);
  if (data?.length) portfolio = data.map((p: any) => ({ title: p.title, desc: p.description, category: p.category, image: p.image_after }));
} catch {}

try {
  const { data } = await supabase.from('site_config').select('key, value').eq('category', 'contact');
  if (data?.length) {
    const m: Record<string, string> = {};
    data.forEach((c: any) => { m[c.key] = c.value; });
    contactInfo = {
      company: m.company_name || FALLBACK_CONTACT.company,
      phone: m.phone || FALLBACK_CONTACT.phone,
      hours: m.business_hours || FALLBACK_CONTACT.hours,
      address: m.address || FALLBACK_CONTACT.address,
      email: m.email || FALLBACK_CONTACT.email,
    };
  }
} catch {}

const currentYear = new Date().getFullYear();

