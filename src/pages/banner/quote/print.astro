---
/**
 * 인쇄물 견적 페이지
 * /banner/quote/print?product={slug}
 *
 * - BannerHeader 공통 헤더 사용
 * - QuoteCalculator React 컴포넌트를 client:load로 렌더링
 * - 제품 slug 파라미터가 없으면 제품 목록을 표시
 */
import Layout from '../../../layouts/Layout.astro';
import BannerHeader from '../../../components/banner/BannerHeader.astro';
import QuoteCalculator from '../../../components/banner/QuoteCalculator';
import { printCategory, getPrintProductBySlug, printProducts } from '../../../data/pricing/products-print';
import type { ProductConfig } from '../../../data/pricing/types';

// --- 연락처 / 서비스 / 메가메뉴 데이터 (BannerHeader 전달용) ---
const contactInfo = {
  company: 'issac.design',
  phone: '010-1234-5678',
  hours: '평일 09:00~18:00 (토 09:00~15:00)',
  address: '서울시 강남구 테헤란로 123',
  email: 'contact@issac.design',
};

const services = [
  { icon: 'banner', title: '배너·거치대', desc: '실내외 배너 거치대 전문 제작·판매' },
  { icon: 'banner', title: '현수막', desc: '일반·장폭·솔벤·라텍스 현수막 제작' },
  { icon: 'banner', title: '인쇄물', desc: '명함·전단지·포스터·스티커·메뉴판' },
];

// 메가메뉴에 인쇄물 카테고리 포함
const megaMenuData = [
  {
    id: 'print',
    name: '인쇄물',
    subcategories: printProducts.map((p) => ({
      label: p.name,
      href: `/banner/quote/print?product=${p.slug}`,
    })),
  },
];

// --- 선택된 제품 확인 ---
const productSlug = Astro.url.searchParams.get('product') || '';
const selectedProduct: ProductConfig | undefined = productSlug
  ? getPrintProductBySlug(productSlug)
  : undefined;
---

<Layout
  title={selectedProduct ? `${selectedProduct.name} 견적 - issac.design` : '인쇄물 견적 - issac.design'}
  description={selectedProduct?.description || '명함, 전단지, 포스터, 스티커, 메뉴판 등 디지털 인쇄물 실시간 견적 계산'}
>
  <!-- 공통 헤더 -->
  <BannerHeader contactInfo={contactInfo} services={services} megaMenuData={megaMenuData} />

  <!-- 메인 콘텐츠 -->
  <main class="print-quote-main">
    {selectedProduct ? (
      <!-- 제품이 선택된 경우: 견적 계산기 렌더링 -->
      <div class="calculator-wrap">
        <QuoteCalculator product={selectedProduct} client:load />
      </div>
    ) : (
      <!-- 제품 미선택: 제품 목록 표시 -->
      <section class="product-select-section">
        <div class="product-select-inner">
          <div class="section-header">
            <h1>인쇄물 견적</h1>
            <p>견적을 받으실 인쇄물 종류를 선택해 주세요</p>
          </div>

          <div class="product-grid">
            {printProducts.map((p) => (
              <a href={`/banner/quote/print?product=${p.slug}`} class="product-card">
                <div class="product-thumb">
                  <img src={p.thumbnail} alt={p.name} loading="lazy" />
                </div>
                <div class="product-info">
                  <span class="product-subcategory">{p.subcategory}</span>
                  <h3 class="product-name">{p.name}</h3>
                  <p class="product-desc">{p.description}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <!-- 하단 안내 -->
  <footer class="print-quote-footer">
    <div class="footer-inner">
      <p>견적 금액은 참고용이며, 실제 주문 시 변동될 수 있습니다.</p>
      <p>대량 주문 및 특수 사양은 별도 문의 바랍니다. <strong>{contactInfo.phone}</strong></p>
    </div>
  </footer>
</Layout>

<style is:global>
  /* ─── 레이아웃 ─── */
  .print-quote-main {
    min-height: 70vh;
    background: #f8f9fa;
  }

  .calculator-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px 16px 64px;
  }

  /* ─── 제품 목록 ─── */
  .product-select-section {
    padding: 48px 0 80px;
  }

  .product-select-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .product-select-section .section-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .product-select-section .section-header h1 {
    font-size: 1.75rem;
    font-weight: 800;
    color: #222;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .product-select-section .section-header p {
    font-size: 15px;
    color: #888;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .product-card {
    display: block;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .product-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }

  .product-thumb {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f0f0f0;
  }

  .product-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .product-card:hover .product-thumb img {
    transform: scale(1.05);
  }

  .product-info {
    padding: 16px 20px 20px;
  }

  .product-subcategory {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    color: #1A4D2E;
    background: #e8f5ee;
    padding: 2px 8px;
    border-radius: 4px;
    margin-bottom: 8px;
    letter-spacing: 0.02em;
  }

  .product-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: #222;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }

  .product-desc {
    font-size: 13px;
    color: #999;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ─── 푸터 ─── */
  .print-quote-footer {
    background: #f0f0f0;
    border-top: 1px solid #e0e0e0;
    padding: 24px 0;
  }

  .footer-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 16px;
    text-align: center;
  }

  .footer-inner p {
    font-size: 13px;
    color: #888;
    line-height: 1.7;
  }

  .footer-inner strong {
    color: #333;
  }

  /* ─── 반응형 ─── */
  @media (max-width: 640px) {
    .product-grid {
      grid-template-columns: 1fr;
    }

    .calculator-wrap {
      padding: 16px 8px 48px;
    }

    .product-select-section .section-header h1 {
      font-size: 1.35rem;
    }
  }
</style>
