---
/**
 * ProductSimulatorSection
 * Astro wrapper for the React-based 3D ProductSimulator
 * Displays on product detail pages
 */

import ProductSimulator from './ProductSimulator';
---

<section class="simulator-section" data-simulator-section>
  <ProductSimulator client:visible />
</section>

<style>
  /* ============================================
     Product Simulator Section
     ============================================ */

  .simulator-section {
    position: relative;
    width: 100%;
    padding: var(--space-4xl) 0;
    background: linear-gradient(180deg, var(--background) 0%, var(--background-elevated) 100%);
    border-top: 1px solid var(--border);
  }

  /* Container */
  :global(.product-simulator__container) {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  /* Header */
  :global(.product-simulator__header) {
    text-align: center;
    margin-bottom: 0;
  }

  :global(.product-simulator__title) {
    font-family: var(--font-heading);
    font-size: var(--font-size-3xl);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-md);
    letter-spacing: var(--letter-spacing-tight);
  }

  :global(.product-simulator__description) {
    font-size: var(--font-size-base);
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  :global(.product-simulator__tips) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    font-size: var(--font-size-xs);
    color: var(--text-muted);
  }

  :global(.product-simulator__tips-mobile) {
    display: none;
  }

  :global(.product-simulator__tips-divider) {
    color: var(--border);
  }

  @media (max-width: 719px) {
    :global(.product-simulator__tips) {
      flex-direction: column;
      gap: var(--space-xs);
    }

    :global(.product-simulator__tips-desktop) {
      display: none;
    }

    :global(.product-simulator__tips-mobile) {
      display: inline;
    }

    :global(.product-simulator__tips-divider) {
      display: none;
    }
  }

  /* Topbar: title centered, upload top-right */
  :global(.product-simulator__topbar) {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  :global(.product-simulator__upload-bar) {
    position: absolute;
    top: 0;
    right: 0;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  :global(.sim-upload-btn) {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-sm) var(--space-md);
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--text-secondary);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  :global(.sim-upload-btn:hover) {
    background: rgba(255, 255, 255, 0.12);
    border-color: var(--primary-light);
    color: var(--text-primary);
  }

  :global(.sim-upload-btn--sample) {
    background: rgba(26, 77, 46, 0.15);
    border-color: rgba(76, 175, 80, 0.3);
    color: var(--primary-light);
  }

  :global(.sim-upload-btn--sample:hover) {
    background: rgba(26, 77, 46, 0.25);
    border-color: var(--primary-light);
  }

  /* Content - Full Width */
  :global(.product-simulator__content) {
    display: block;
  }

  /* Canvas */
  :global(.product-simulator__canvas) {
    position: relative;
    width: 100%;
    height: 85vh;
    min-height: 600px;
    max-height: 1000px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: #1a1a2e;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Canvas Overlay Buttons (shared) */
  :global(.sim-canvas-btn),
  :global(.sim-daynight-btn) {
    position: absolute;
    z-index: 5;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(8px);
    color: var(--text-primary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s ease;
  }

  :global(.sim-canvas-btn:hover),
  :global(.sim-daynight-btn:hover) {
    background: rgba(0, 0, 0, 0.6);
    border-color: rgba(255, 255, 255, 0.3);
    transform: scale(1.1);
  }

  /* Tooltip — appears on left of right-side buttons */
  :global([data-tooltip]) {
    position: absolute;
  }

  :global([data-tooltip])::after {
    content: attr(data-tooltip);
    position: absolute;
    right: calc(100% + 10px);
    top: 50%;
    transform: translateY(-50%);
    padding: 5px 10px;
    background: rgba(0, 0, 0, 0.85);
    color: #fff;
    font-size: 12px;
    font-weight: 500;
    white-space: nowrap;
    border-radius: 6px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease;
    z-index: 20;
  }

  :global([data-tooltip])::before {
    content: '';
    position: absolute;
    right: calc(100% + 4px);
    top: 50%;
    transform: translateY(-50%);
    border: 5px solid transparent;
    border-left-color: rgba(0, 0, 0, 0.85);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease;
    z-index: 20;
  }

  :global([data-tooltip]:hover)::after,
  :global([data-tooltip]:hover)::before {
    opacity: 1;
  }

  /* Left-side buttons: tooltip appears on right */
  :global(.sim-board-settings-btn[data-tooltip])::after,
  :global(.sim-sign-upload-btn[data-tooltip])::after,
  :global(.sim-bgupload-btn[data-tooltip])::after {
    right: auto;
    left: calc(100% + 10px);
  }

  :global(.sim-board-settings-btn[data-tooltip])::before,
  :global(.sim-sign-upload-btn[data-tooltip])::before,
  :global(.sim-bgupload-btn[data-tooltip])::before {
    right: auto;
    left: calc(100% + 4px);
    border-left-color: transparent;
    border-right-color: rgba(0, 0, 0, 0.85);
  }

  :global(.sim-canvas-btn.active) {
    background: rgba(76, 175, 80, 0.5);
    border-color: rgba(76, 175, 80, 0.8);
  }

  /* Day/Night Button - top right */
  :global(.sim-daynight-btn) {
    top: var(--space-md);
    right: var(--space-md);
  }

  :global(.sim-daynight-btn.day) {
    background: rgba(255, 255, 255, 0.5);
    border-color: rgba(0, 0, 0, 0.15);
    color: #333;
  }

  :global(.sim-daynight-btn.day:hover) {
    background: rgba(255, 255, 255, 0.7);
    border-color: rgba(0, 0, 0, 0.25);
  }

  /* Wireframe Button - below day/night */
  :global(.sim-wireframe-btn) {
    top: calc(var(--space-md) + 44px);
    right: var(--space-md);
  }

  /* Backboard Button - below wireframe */
  :global(.sim-backboard-btn) {
    top: calc(var(--space-md) + 88px);
    right: var(--space-md);
  }

  /* Background Image Button - below backboard */
  :global(.sim-bgimage-btn) {
    top: calc(var(--space-md) + 132px);
    right: var(--space-md);
  }

  /* Background Upload Button - left side, below sign upload */
  :global(.sim-bgupload-btn) {
    top: calc(var(--space-md) + 88px);
    left: var(--space-md);
    right: auto;
    cursor: pointer;
  }

  /* Background Image */
  :global(.sim-bg-image) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    z-index: 0;
    pointer-events: none;
    user-select: none;
  }

  /* Board Settings Button - top left */
  :global(.sim-board-settings-btn) {
    top: var(--space-md);
    left: var(--space-md);
    right: auto;
  }

  /* Sign Image Upload — left side, below settings */
  :global(.sim-sign-upload-btn) {
    top: calc(var(--space-md) + 44px);
    left: var(--space-md);
    right: auto;
    cursor: pointer;
  }


  /* Board Settings Popover */
  :global(.sim-board-popover) {
    position: absolute;
    top: var(--space-md);
    left: calc(var(--space-md) + 44px);
    z-index: 10;
    width: 220px;
    background: rgba(15, 15, 20, 0.92);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-md);
    padding: var(--space-md);
  }

  :global(.sim-board-popover__header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-sm);
  }

  :global(.sim-board-popover__header span) {
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
  }

  :global(.sim-board-popover__close) {
    width: 24px;
    height: 24px;
    border: none;
    background: rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }

  :global(.sim-board-popover__close:hover) {
    background: rgba(255, 255, 255, 0.15);
  }

  :global(.sim-board-popover__divider) {
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    margin: var(--space-sm) 0;
  }


  /* AR Video Feed */
  :global(.sim-ar-video) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  :global(.product-simulator__canvas canvas) {
    position: relative;
    z-index: 1;
  }

  /* AR Fullscreen — Fullscreen API */
  :global(.product-simulator__canvas:fullscreen),
  :global(.product-simulator__canvas:-webkit-full-screen) {
    width: 100vw !important;
    height: 100vh !important;
    max-height: none !important;
    min-height: 0 !important;
    border-radius: 0 !important;
    background: #000 !important;
    border: none !important;
  }

  /* AR Fullscreen — CSS fallback (iOS/PWA) */
  :global(.product-simulator__canvas.ar-fullscreen) {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    bottom: 0 !important;
    z-index: 9999 !important;
    width: 100vw !important;
    height: 100vh !important;
    height: 100dvh !important;
    max-width: none !important;
    max-height: none !important;
    min-height: 0 !important;
    border-radius: 0 !important;
    background: #000 !important;
    border: none !important;
    overflow: visible !important;
    transform: none !important;
  }

  /* AR 모드일 때 부모 요소들이 fixed를 방해하지 않도록 */
  :global(body:has(.ar-fullscreen)) {
    overflow: hidden !important;
  }
  :global(body:has(.ar-fullscreen) .simulator-section),
  :global(body:has(.ar-fullscreen) .product-simulator),
  :global(body:has(.ar-fullscreen) .product-simulator__container),
  :global(body:has(.ar-fullscreen) .product-simulator__content) {
    overflow: visible !important;
    transform: none !important;
    contain: none !important;
    will-change: auto !important;
  }

  /* AR Button - below bg image toggle */
  :global(.sim-ar-btn) {
    display: flex;
    position: absolute;
    top: calc(var(--space-md) + 176px);
    right: var(--space-md);
    z-index: 5;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(8px);
    color: #fff;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    transition: all 0.25s ease;
  }

  :global(.sim-ar-btn:hover) {
    background: rgba(0, 0, 0, 0.6);
    border-color: rgba(255, 255, 255, 0.3);
    transform: scale(1.1);
  }

  :global(.sim-ar-btn.active) {
    background: rgba(244, 67, 54, 0.7);
    border-color: rgba(244, 67, 54, 0.9);
  }

  :global(.sim-ar-btn.active:hover) {
    background: rgba(244, 67, 54, 0.9);
  }

  /* AR CTA */
  :global(.sim-ar-cta) {
    position: absolute;
    bottom: var(--space-xl);
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
    padding: var(--space-sm) var(--space-xl);
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    border-radius: var(--radius-full, 999px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    animation: sim-ar-cta-pulse 2s ease-in-out infinite;
  }

  :global(.sim-ar-cta span) {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: #fff;
    white-space: nowrap;
  }

  @keyframes sim-ar-cta-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  /* AR Flip Camera */
  :global(.sim-ar-flip) {
    position: absolute;
    bottom: var(--space-xl);
    right: var(--space-lg);
    z-index: 5;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }

  :global(.sim-ar-flip:hover) {
    background: rgba(0, 0, 0, 0.7);
    transform: scale(1.1);
  }

  :global(.sim-ar-flip:active) {
    transform: scale(0.95);
  }

  /* Loading State */
  :global(.product-simulator__loading) {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    background: rgba(26, 26, 46, 0.9);
    color: var(--text-primary);
    font-size: var(--font-size-sm);
    z-index: 10;
  }

  :global(.spinner) {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(255, 255, 255, 0.1);
    border-top-color: var(--primary-light);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Error State */
  :global(.product-simulator__error) {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    padding: var(--space-lg);
    background: rgba(244, 67, 54, 0.1);
    border: 1px solid rgba(244, 67, 54, 0.3);
    border-radius: var(--radius-md);
    color: #ff6b6b;
    font-size: var(--font-size-sm);
    text-align: center;
    max-width: 300px;
  }

  /* Controls */
  :global(.product-simulator__controls) {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  :global(.simulator-control) {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  :global(.simulator-control__label) {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
  }

  :global(.simulator-control__hint) {
    font-size: var(--font-size-xs);
    color: var(--text-muted);
    margin-top: var(--space-xs);
  }

  /* Upload Button */
  :global(.simulator-upload) {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: var(--space-xl);
    background: rgba(255, 255, 255, 0.03);
    border: 2px dashed rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-base);
  }

  :global(.simulator-upload:hover) {
    background: rgba(255, 255, 255, 0.05);
    border-color: var(--primary-light);
  }

  :global(.simulator-upload svg) {
    width: 32px;
    height: 32px;
    color: var(--primary-light);
  }

  :global(.simulator-upload span) {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--text-secondary);
  }

  /* Material Presets */
  :global(.simulator-presets) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  :global(.simulator-preset) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-lg) var(--space-md);
    background: rgba(255, 255, 255, 0.03);
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-base);
  }

  :global(.simulator-preset:hover) {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(76, 175, 80, 0.3);
  }

  :global(.simulator-preset.active) {
    background: linear-gradient(135deg, rgba(26, 77, 46, 0.2) 0%, rgba(76, 175, 80, 0.1) 100%);
    border-color: var(--primary-light);
  }

  :global(.simulator-preset__icon) {
    font-size: 2rem;
  }

  :global(.simulator-preset__label) {
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--text-secondary);
    white-space: nowrap;
  }

  :global(.simulator-preset.active .simulator-preset__label) {
    color: var(--primary-light);
  }

  /* Info */
  :global(.simulator-info) {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background: rgba(76, 175, 80, 0.05);
    border: 1px solid rgba(76, 175, 80, 0.2);
    border-radius: var(--radius-md);
  }

  :global(.simulator-info__item) {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
  }

  :global(.simulator-info__item svg) {
    width: 16px;
    height: 16px;
    color: var(--primary-light);
    flex-shrink: 0;
  }

  /* ============================================
     Responsive
     ============================================ */

  /* Tablet */
  @media (max-width: 1023px) {
    :global(.product-simulator__canvas) {
      height: 60vh;
      min-height: 400px;
    }
  }

  /* Mobile */
  @media (max-width: 719px) {
    .simulator-section {
      padding: var(--space-lg) 0;
    }

    :global(.product-simulator__container) {
      padding: 0 var(--space-sm);
    }

    :global(.product-simulator__topbar) {
      padding-top: var(--space-sm);
    }

    :global(.product-simulator__upload-bar) {
      position: relative;
      top: auto;
      right: auto;
    }

    :global(.product-simulator__header) {
      margin-bottom: 0;
    }

    :global(.product-simulator__title) {
      font-size: var(--font-size-xl);
    }

    :global(.product-simulator__description) {
      font-size: var(--font-size-xs);
    }

    :global(.product-simulator__canvas) {
      height: 70vh;
      min-height: 300px;
      max-height: none;
      border-radius: var(--radius-md);
    }

    :global(.sim-canvas-btn),
    :global(.sim-daynight-btn) {
      width: 32px;
      height: 32px;
    }

    :global(.sim-ar-btn) {
      width: 32px;
      height: 32px;
    }
  }

  /* Empty state */
  :global(.product-simulator__empty) {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: var(--space-md);
    opacity: 0.4;
    color: var(--text-secondary);
  }

  :global(.product-simulator__empty p) {
    font-size: var(--font-size-base);
    text-align: center;
    padding: 0 var(--space-lg);
  }

  /* ─── Collapsible Sections ─── */

  :global(.sim-section) {
    margin-bottom: 2px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  :global(.sim-section__header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--space-sm) var(--space-md);
    background: rgba(255, 255, 255, 0.04);
    border: none;
    cursor: pointer;
    color: var(--text-secondary);
    transition: background 0.15s;
  }

  :global(.sim-section__header:hover) {
    background: rgba(255, 255, 255, 0.08);
  }

  :global(.sim-section__title) {
    font-size: var(--font-size-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
  }

  :global(.sim-section__arrow) {
    transition: transform 0.2s;
    color: var(--text-muted);
  }

  :global(.sim-section__arrow.open) {
    transform: rotate(180deg);
  }

  :global(.sim-section__body) {
    padding: var(--space-md);
  }

  /* ─── Stepper ─── */

  :global(.sim-stepper) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-sm);
  }

  :global(.sim-stepper__label) {
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
  }

  :global(.sim-stepper__controls) {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  :global(.sim-stepper__btn) {
    width: 28px;
    height: 28px;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-primary);
    cursor: pointer;
    font-size: var(--font-size-sm);
    display: flex;
    align-items: center;
