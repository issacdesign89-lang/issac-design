---
/**
 * Shop Hero Background Component
 * 4 rotating videos with crossfade transitions + mobile poster fallback
 */

import { Image } from 'astro:assets';
import { supabase } from '../../lib/supabase';

const FALLBACK_SLIDES = [
  {
    webm: '/videos/hero1-opt.webm',
    mp4: '/videos/hero1-opt.mp4',
    poster: '/videos/hero1-poster.jpg',
  },
  {
    webm: '/videos/hero2-opt.webm',
    mp4: '/videos/hero2-opt.mp4',
    poster: '/videos/hero2-poster.jpg',
  },
  {
    webm: '/videos/hero3-opt.webm',
    mp4: '/videos/hero3-opt.mp4',
    poster: '/videos/hero3-poster.jpg',
  },
  {
    webm: '/videos/hero4-opt.webm',
    mp4: '/videos/hero4-opt.mp4',
    poster: '/videos/hero4-poster.jpg',
  },
];

let slides = FALLBACK_SLIDES;
try {
  const { data: dbSlides, error } = await supabase
    .from('hero_slides')
    .select('*')
    .eq('page', 'shop')
    .order('slide_index');
  if (!error && dbSlides && dbSlides.length > 0) {
    slides = dbSlides.map((s: any, i: number) => ({
      webm: s.video_webm_url || FALLBACK_SLIDES[i]?.webm || '',
      mp4: s.video_url || FALLBACK_SLIDES[i]?.mp4 || '',
      poster: s.poster_url || FALLBACK_SLIDES[i]?.poster || '',
    }));
  }
} catch {}
---

<div class="shop-hero__bg" data-shop-hero-bg>
  {slides.map((slide, idx) => (
    <div
      class:list={['shop-hero__video-wrap', { 'is-active': idx === 0 }]}
      data-shop-hero-bg-wrapper
      data-slide-index={idx}
    >
      <!-- Mobile fallback image -->
      <Image
        class="shop-hero__poster"
        src={slide.poster}
        alt=""
        loading={idx === 0 ? 'eager' : 'lazy'}
        decoding="async"
        width={1920}
        height={1080}
        format="webp"
        quality={80}
      />
      <!-- Background video -->
      <video
        class="shop-hero__video"
        autoplay={idx === 0}
        muted
        loop
        playsinline
        preload={idx === 0 ? 'auto' : 'none'}
        poster={slide.poster}
        data-shop-hero-video
        data-slide-index={idx}
      >
        {slide.webm && <source src={slide.webm} type="video/webm" />}
        <source src={slide.mp4} type="video/mp4" />
      </video>
    </div>
  ))}
  <div class="shop-hero__overlay"></div>
</div>

<style>
  .shop-hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .shop-hero__video-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
    will-change: opacity;
    opacity: 0;
    transition: opacity 1.2s ease-in-out;
  }

  .shop-hero__video-wrap.is-active {
    opacity: 1;
  }

  .shop-hero__video {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    object-fit: cover;
    pointer-events: none;
    filter: brightness(0.4) saturate(1.15);
  }

  .shop-hero__poster {
    display: none;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.5) saturate(1.2);
  }

  .shop-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.75) 0%,
      rgba(0, 0, 0, 0.55) 35%,
      rgba(0, 0, 0, 0.60) 65%,
      rgba(0, 0, 0, 0.85) 100%
    );
  }

  @media (max-width: 719px) {
    .shop-hero__video {
      display: none;
    }

    .shop-hero__poster {
      display: block;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .shop-hero__video {
      display: none;
    }

    .shop-hero__poster {
      display: block;
    }

    .shop-hero__video-wrap {
      transition: none;
    }
  }
</style>
