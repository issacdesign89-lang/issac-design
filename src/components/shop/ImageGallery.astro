---
/**
 * ImageGallery Component
 * Product image gallery with thumbnails, lightbox modal, material toggle, and lighting switch
 */
import { Image } from 'astro:assets';

interface Props {
  images: string[];
  productName: string;
  materialImages?: {
    acrylic?: string;
    stainless?: string;
    aluminum?: string;
    copper?: string;
  };
  lightingImages?: {
    off?: string;
    on?: string;
  };
}

const { images: rawImages, productName, materialImages, lightingImages } = Astro.props;
const images = rawImages?.filter(Boolean) ?? [];
const hasImages = images.length > 0;
---

<div class="image-gallery" data-image-gallery>
  <!-- Material Toggle (if materialImages available) -->
  {materialImages && Object.keys(materialImages).length > 0 && (
    <div class="image-gallery__controls">
      <div class="image-gallery__control-group">
        <span class="image-gallery__control-label">소재 선택</span>
        <div class="image-gallery__material-toggle" data-material-toggle>
          {materialImages.acrylic && (
            <button
              class="material-btn material-btn--active"
              data-material="acrylic"
              data-material-src={materialImages.acrylic}
              aria-label="아크릴 소재"
            >
              아크릴
            </button>
          )}
          {materialImages.stainless && (
            <button
              class="material-btn"
              data-material="stainless"
              data-material-src={materialImages.stainless}
              aria-label="스테인리스 소재"
            >
              스테인리스
            </button>
          )}
          {materialImages.aluminum && (
            <button
              class="material-btn"
              data-material="aluminum"
              data-material-src={materialImages.aluminum}
              aria-label="알루미늄 소재"
            >
              알루미늄
            </button>
          )}
          {materialImages.copper && (
            <button
              class="material-btn"
              data-material="copper"
              data-material-src={materialImages.copper}
              aria-label="동판 소재"
            >
              동판
            </button>
          )}
        </div>
      </div>
    </div>
  )}

  <!-- Lighting Switch (if lightingImages available) -->
  {lightingImages && lightingImages.off && lightingImages.on && (
    <div class="image-gallery__controls">
      <div class="image-gallery__control-group">
        <span class="image-gallery__control-label">조명</span>
        <div class="image-gallery__lighting-switch" data-lighting-switch>
          <button
            class="lighting-btn"
            data-lighting="off"
            data-lighting-src={lightingImages.off}
            aria-label="조명 OFF"
          >
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M10 3v1M10 16v1M17 10h-1M4 10H3M15.657 4.343l-.707.707M5.05 14.95l-.707.707M15.657 15.657l-.707-.707M5.05 5.05l-.707-.707" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            OFF
          </button>
          <button
            class="lighting-btn lighting-btn--active"
            data-lighting="on"
            data-lighting-src={lightingImages.on}
            aria-label="조명 ON"
          >
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M10 3v1M10 16v1M17 10h-1M4 10H3M15.657 4.343l-.707.707M5.05 14.95l-.707.707M15.657 15.657l-.707-.707M5.05 5.05l-.707-.707" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="10" cy="10" r="3" fill="currentColor"/>
            </svg>
            ON
          </button>
        </div>
      </div>
    </div>
  )}

  <!-- Main Image -->
  <div class="image-gallery__main" data-gallery-main>
    {hasImages ? (
      <Image
        src={images[0]}
        alt={productName}
        class="image-gallery__main-img"
        loading="eager"
        decoding="async"
        width={800}
        height={600}
        data-gallery-main-img
        format="webp"
        quality={85}
      />
    ) : (
      <div class="image-gallery__placeholder" data-gallery-main-img>
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
        <span>이미지 없음</span>
      </div>
    )}
  </div>

  <!-- Thumbnails -->
  {images.length > 1 && (
    <div class="image-gallery__thumbnails" data-gallery-thumbnails>
      {images.map((img, i) => (
        <button
          class={`image-gallery__thumb ${i === 0 ? 'image-gallery__thumb--active' : ''}`}
          data-gallery-thumb
          data-index={i}
          aria-label={`${productName} image ${i + 1}`}
        >
          <Image
            src={img}
            alt={`${productName} - ${i + 1}`}
            loading="lazy"
            decoding="async"
            width={200}
            height={150}
            format="webp"
            quality={70}
          />
        </button>
      ))}
    </div>
  )}

  <!-- Lightbox Modal -->
  {hasImages && (
    <div class="image-gallery__lightbox" data-gallery-lightbox aria-hidden="true">
      <div class="image-gallery__lightbox-backdrop" data-gallery-lightbox-close></div>
      <button
        class="image-gallery__lightbox-close"
        data-gallery-lightbox-close
        aria-label="Close lightbox"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <img
        class="image-gallery__lightbox-img"
        data-gallery-lightbox-img
        src={images[0]}
        alt={productName}
      />
    </div>
  )}
</div>

<style>
  /* Gallery Container */
  .image-gallery {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    width: 100%;
  }

  /* Controls */
  .image-gallery__controls {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-md);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .image-gallery__control-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .image-gallery__control-label {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
  }

  /* Material Toggle */
  .image-gallery__material-toggle {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .material-btn {
    padding: var(--space-sm) var(--space-lg);
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--text-secondary);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .material-btn:hover {
    color: var(--text-primary);
    border-color: var(--primary);
    background: rgba(26, 77, 46, 0.1);
  }

  .material-btn--active {
    color: var(--text-primary);
    border-color: var(--primary);
    background: var(--primary);
  }

  .material-btn--active:hover {
    background: var(--primary-hover);
  }

  /* Lighting Switch */
  .image-gallery__lighting-switch {
    display: flex;
    gap: var(--space-sm);
  }

  .lighting-btn {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-sm) var(--space-lg);
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--text-secondary);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .lighting-btn svg {
    flex-shrink: 0;
  }

  .lighting-btn:hover {
    color: var(--text-primary);
    border-color: var(--primary);
    background: rgba(26, 77, 46, 0.1);
  }

  .lighting-btn--active {
    color: var(--text-primary);
    border-color: var(--primary);
    background: var(--primary);
  }

  .lighting-btn--active:hover {
    background: var(--primary-hover);
  }

  /* Main Image */
  .image-gallery__main {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    cursor: pointer;
  }

  .image-gallery__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    color: var(--text-tertiary, #666);
    font-size: var(--font-size-sm);
  }

  .image-gallery__main-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base), opacity var(--transition-base);
  }

  .image-gallery__main:hover .image-gallery__main-img {
    transform: scale(1.05);
  }

  .image-gallery__main-img.is-fading {
    opacity: 0;
  }

  /* Thumbnails */
  .image-gallery__thumbnails {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-sm);
  }

  .image-gallery__thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--surface-light);
    border: 2px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    padding: 0;
    cursor: pointer;
    transition: border-color var(--transition-base), opacity var(--transition-base);
  }

  .image-gallery__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-gallery__thumb:hover {
    border-color: var(--border-light);
  }

  .image-gallery__thumb--active {
    border-color: var(--primary);
  }

  .image-gallery__thumb--active:hover {
    border-color: var(--primary);
  }

  /* Lightbox */
  .image-gallery__lightbox {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--transition-base), visibility var(--transition-base);
  }

  .image-gallery__lightbox.is-open {
    opacity: 1;
    visibility: visible;
  }

  .image-gallery__lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.95);
  }

  .image-gallery__lightbox-close {
    position: absolute;
    top: var(--space-xl);
    right: var(--space-xl);
    z-index: 1;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: var(--radius-full);
    color: var(--text-primary);
    cursor: pointer;
    transition: all var(--transition-base);
    padding: 0;
  }

  .image-gallery__lightbox-close:hover {
    border-color: var(--text-primary);
    background: rgba(255, 255, 255, 0.1);
    transform: scale(1.1);
  }

  .image-gallery__lightbox-img {
    position: relative;
    z-index: 1;
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-md);
    pointer-events: none;
  }

  /* Responsive */
  @media (max-width: 719px) {
    .image-gallery__thumbnails {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: var(--space-sm);
      padding-bottom: var(--space-xs);
    }

    .image-gallery__thumb {
      flex: 0 0 25%;
      min-width: 70px;
      scroll-snap-align: start;
    }

    .image-gallery__lightbox-close {
      top: var(--space-md);
      right: var(--space-md);
    }
  }
</style>

<script>
  function initGallery() {
    const galleries = document.querySelectorAll<HTMLElement>('[data-image-gallery]');

    galleries.forEach((gallery) => {
      const mainImg = gallery.querySelector<HTMLImageElement>('[data-gallery-main-img]');
      const mainContainer = gallery.querySelector<HTMLElement>('[data-gallery-main]');
      const thumbs = gallery.querySelectorAll<HTMLButtonElement>('[data-gallery-thumb]');
      const lightbox = gallery.querySelector<HTMLElement>('[data-gallery-lightbox]');
      const lightboxImg = gallery.querySelector<HTMLImageElement>('[data-gallery-lightbox-img]');
      const lightboxCloseButtons = gallery.querySelectorAll<HTMLElement>('[data-gallery-lightbox-close]');

      if (!mainImg || !lightbox || !lightboxImg) return;

      let activeIndex = 0;

      // Material Toggle
      const materialButtons = gallery.querySelectorAll<HTMLButtonElement>('[data-material]');
      materialButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const materialSrc = btn.dataset.materialSrc;
          if (!materialSrc) return;

          // Fade out
          mainImg.classList.add('is-fading');

          setTimeout(() => {
            mainImg.src = materialSrc;
            mainImg.classList.remove('is-fading');
          }, 300);

          // Update active material button
          materialButtons.forEach((b) => b.classList.remove('material-btn--active'));
          btn.classList.add('material-btn--active');
        });
      });

      // Lighting Switch
      const lightingButtons = gallery.querySelectorAll<HTMLButtonElement>('[data-lighting]');
      lightingButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const lightingSrc = btn.dataset.lightingSrc;
          if (!lightingSrc) return;

          // Fade out
          mainImg.classList.add('is-fading');

          setTimeout(() => {
            mainImg.src = lightingSrc;
            mainImg.classList.remove('is-fading');
          }, 300);

          // Update active lighting button
          lightingButtons.forEach((b) => b.classList.remove('lighting-btn--active'));
          btn.classList.add('lighting-btn--active');
        });
      });

      // Thumbnail click: swap main image with fade
      thumbs.forEach((thumb) => {
        thumb.addEventListener('click', () => {
          const index = Number(thumb.dataset.index);
          if (index === activeIndex) return;

          const thumbImg = thumb.querySelector('img');
          if (!thumbImg) return;

          // Fade out
          mainImg.classList.add('is-fading');

          setTimeout(() => {
            mainImg.src = thumbImg.src;
            mainImg.alt = thumbImg.alt;
            mainImg.classList.remove('is-fading');
          }, 300);

          // Update active thumbnail
          thumbs.forEach((t) => t.classList.remove('image-gallery__thumb--active'));
          thumb.classList.add('image-gallery__thumb--active');

          activeIndex = index;
        });
      });

      // Open lightbox on main image click
      if (mainContainer) {
        mainContainer.addEventListener('click', () => {
          lightboxImg.src = mainImg.src;
          lightboxImg.alt = mainImg.alt;
          lightbox.classList.add('is-open');
          lightbox.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
        });
      }

      // Close lightbox
      function closeLightbox() {
        lightbox.classList.remove('is-open');
        lightbox.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }

      lightboxCloseButtons.forEach((btn) => {
        btn.addEventListener('click', closeLightbox);
      });

      // ESC key closes lightbox
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && lightbox.classList.contains('is-open')) {
          closeLightbox();
        }
      });
    });
  }

  // Initialize on DOM ready and after Astro page transitions
  document.addEventListener('DOMContentLoaded', initGallery);
  document.addEventListener('astro:page-load', initGallery);
</script>
