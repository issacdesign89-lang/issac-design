---
/**
 * Shop Hero Section — 4-slide Rolling Hero
 * 4개 문구 + 4개 영상 롤링 전환
 * 듀얼 CTA + 카테고리 퀵 네비
 */
import ShopHeroBackground from './ShopHeroBackground.astro';
import HeroSimulatorPreview from './HeroSimulatorPreview.tsx';
import { Image } from 'astro:assets';
import { getProducts } from '../../lib/data-fetchers';
import { supabase } from '../../lib/supabase';

const { products } = await getProducts();
const categoryOrder = ['led-channel', 'neon', 'acrylic', 'banner', 'protruding', 'rooftop'];
const featuredProducts = categoryOrder
  .map((catId) => products.find((p) => p.category === catId && p.isFeatured))
  .filter((p): p is NonNullable<typeof p> => !!p && !!p.thumbnail);

// 4개 슬라이드 문구 (폴백)
const FALLBACK_HERO_SLIDES = [
  {
    eyebrow: '감각적인 사인 디자인 · issac.design',
    line1: '내 가게에 딱 맞는',
    line2: '간판을 찾아보세요',
    desc: 'LED 채널간판, 네온사인, 현수막, 돌출간판 등<br class="hide-mobile" />온라인에서 비교하고 바로 견적받으세요',
  },
  {
    eyebrow: 'Premium Signage · issac.design',
    line1: '브랜드의 첫인상을',
    line2: '디자인합니다',
    desc: '세련된 감각과 섬세한 디테일로<br class="hide-mobile" />브랜드의 가치를 높이는 맞춤형 간판',
  },
  {
    eyebrow: 'Neon & LED · issac.design',
    line1: '빛으로 완성하는',
    line2: '당신의 브랜드',
    desc: '네온사인부터 LED 채널까지<br class="hide-mobile" />다양한 조명 간판으로 매장의 분위기를 만듭니다',
  },
  {
    eyebrow: 'Free Consultation · issac.design',
    line1: '무료 상담으로',
    line2: '시작하세요',
    desc: '전문 디자이너의 1:1 맞춤 상담으로<br class="hide-mobile" />최적의 간판을 제안받으세요',
  },
];

let heroSlides = FALLBACK_HERO_SLIDES;
try {
  const { data: dbSlides, error } = await supabase
    .from('hero_slides')
    .select('*')
    .eq('page', 'shop')
    .order('slide_index');
  if (!error && dbSlides && dbSlides.length > 0) {
    heroSlides = dbSlides.map((s: any) => ({
      eyebrow: s.eyebrow ?? '',
      line1: s.title_line1 ?? '',
      line2: s.title_line2 ?? '',
      desc: s.subtitle ?? '',
    }));
  }
} catch {}
---

<section class="shop-hero" data-shop-hero>
  <!-- LAYER 1: Background (4 videos) -->
  <ShopHeroBackground />

  <!-- LAYER 2: Content -->
  <div class="shop-hero__container">
    <div class="shop-hero__content" data-shop-hero-content>

      <!-- Left: Text slides + indicators + CTA -->
      <div class="shop-hero__left">
        <!-- Slide Text Sets -->
        <div class="shop-hero__slides" data-hero-slides>
          {heroSlides.map((slide, idx) => (
            <div
              class:list={['shop-hero__slide', { 'is-active': idx === 0 }]}
              data-hero-slide={idx}
            >
              <span class="shop-hero__eyebrow" data-shop-hero-eyebrow>
                {slide.eyebrow}
              </span>
              <h2 class="shop-hero__headline">
                <span class="shop-hero__headline-line">
                  <span class="shop-hero__headline-text" data-split-text>{slide.line1}</span>
                </span>
                <span class="shop-hero__headline-line">
                  <span class="shop-hero__headline-text shop-hero__headline-text--accent" data-split-text>{slide.line2}</span>
                </span>
              </h2>
              <p class="shop-hero__desc" data-shop-hero-desc set:html={slide.desc} />
            </div>
          ))}
        </div>

        <!-- Slide Indicators -->
        <div class="shop-hero__indicators" data-hero-indicators>
          {heroSlides.map((_, idx) => (
            <button
              class:list={['shop-hero__indicator', { 'is-active': idx === 0 }]}
              data-hero-indicator={idx}
              type="button"
              aria-label={`슬라이드 ${idx + 1}`}
            >
              <span class="shop-hero__indicator-fill"></span>
            </button>
          ))}
        </div>

        <!-- Dual CTA -->
        <div class="shop-hero__cta" data-shop-hero-cta>
          <a href="#products" class="shop-hero__cta-btn shop-hero__cta-btn--primary" data-magnetic>
            <span>제품 둘러보기</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/shop/quote" class="shop-hero__cta-btn shop-hero__cta-btn--secondary" data-magnetic>
            <span>무료 견적 문의</span>
          </a>
          <button class="shop-hero__cta-btn shop-hero__cta-btn--chat" data-open-chat type="button" data-magnetic>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
              <path d="M8 10h.01M12 10h.01M16 10h.01"/>
            </svg>
            <span>AI 상담</span>
          </button>
        </div>
      </div>

      <!-- Right: 3D Simulator Preview -->
      <div class="shop-hero__simulator-wrap">
        <p class="shop-hero__sim-desc"><span class="shop-hero__sim-desc-accent">시뮬레이션</span>으로 가게 간판 디자인을 확인해보세요</p>
        <div class="shop-hero__simulator" data-shop-hero-simulator>
          <HeroSimulatorPreview client:visible />
        </div>
        <a href="/shop/simulator" class="shop-hero__sim-cta">
          <span>3D 시뮬레이터 체험해 보세요</span>
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

    </div>

    <!-- Category Products Showcase — Marquee (full width, outside grid) -->
    <div class="shop-hero__showcase" data-shop-hero-categories aria-label="대표 제품">
      <div class="shop-hero__showcase-track">
        {[...featuredProducts, ...featuredProducts, ...featuredProducts].map((product) => (
          <a href="#products" class="shop-hero__product-card" data-filter={product.category}>
            <div class="shop-hero__product-img-wrap">
              <Image
                src={product.thumbnail}
                alt={product.name}
                class="shop-hero__product-img"
                loading="lazy"
                decoding="async"
                width={240}
                height={180}
                format="webp"
                quality={75}
              />
            </div>
            <div class="shop-hero__product-info">
              <span class="shop-hero__product-category">{product.categoryName}</span>
              <span class="shop-hero__product-name">{product.name}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- LAYER 3: Scroll Indicator -->
  <button class="shop-hero__scroll" data-shop-hero-scroll aria-label="다음 섹션으로 스크롤" type="button">
    <div class="shop-hero__scroll-line">
      <div class="shop-hero__scroll-dot"></div>
    </div>
  </button>
</section>

<style>
  /* ==================
     Shop Hero — Rolling Hero
     ================== */
  .shop-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    min-height: 600px;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--background);
  }

  /* Container */
  .shop-hero__container {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: calc(var(--header-height, 80px) + var(--space-xl)) var(--container-padding) 0;
  }

  .shop-hero__content {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    align-items: center;
    gap: var(--space-2xl);
  }

  /* Left Column */
  .shop-hero__left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }

  /* Slides Container */
  .shop-hero__slides {
    position: relative;
    width: 100%;
    min-height: 280px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  .shop-hero__slide {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    text-align: left;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  /* Eyebrow */
  .shop-hero__eyebrow {
    display: block;
    font-family: var(--font-primary);
    font-size: var(--font-size-caption, 0.75rem);
    font-weight: 500;
    letter-spacing: 0.15em;
    color: rgba(76, 175, 80, 0.7);
    margin-bottom: var(--space-lg);
  }

  /* Headline */
  .shop-hero__headline {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 0;
    margin-bottom: var(--space-md);
  }

  .shop-hero__headline-line {
    display: block;
    overflow: hidden;
    line-height: 1.1;
  }

  .shop-hero__headline-text {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: clamp(2.8rem, 5vw, 5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-primary);
  }

  .shop-hero__headline-text--accent {
    color: var(--primary-light, #4caf50);
  }

  /* Split-text character spans */
  .shop-hero__headline-text :global(.char) {
    display: inline-block;
  }

  .shop-hero__headline-text :global(.char-space) {
    width: 0.3em;
  }

  /* Description */
  .shop-hero__desc {
    font-family: var(--font-primary);
    font-size: var(--font-size-lg);
    font-weight: 300;
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
    max-width: 520px;
    margin: 0;
    text-align: left;
  }

  .shop-hero__desc :global(.hide-mobile) {
    display: inline;
  }

  /* Indicators */
  .shop-hero__indicators {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-2xl);
    opacity: 0;
  }

  /* ==================
     Right Column — Simulator Preview
     ================== */
  .shop-hero__simulator-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .shop-hero__sim-desc {
    font-size: var(--font-size-base, 1rem);
    font-weight: 600;
    color: #fff;
    text-align: center;
    margin: 0;
    letter-spacing: -0.01em;
    opacity: 0;
  }

  .shop-hero__sim-desc-accent {
    color: var(--primary-light, #4caf50);
  }

  .shop-hero__simulator {
    position: relative;
    width: 100%;
    min-height: 380px;
    border-radius: var(--radius-lg, 12px);
    overflow: hidden;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    opacity: 0;
  }

  .shop-hero__sim-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-xl);
    font-size: var(--font-size-sm);
    font-weight: 500;
    letter-spacing: 0.03em;
    color: #fff;
    background: var(--primary-light, #4caf50);
    border: 1px solid var(--primary-light, #4caf50);
    border-radius: var(--radius-full, 999px);
    text-decoration: none;
    cursor: pointer;
    transition: all var(--transition-base);
    opacity: 0;
  }

  .shop-hero__sim-cta:hover {
    background: #43a047;
    border-color: #43a047;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(76, 175, 80, 0.3);
  }

  .shop-hero__sim-cta svg {
    transition: transform var(--transition-base);
  }

  .shop-hero__sim-cta:hover svg {
    transform: translateX(3px);
  }

  .shop-hero__indicator {
    position: relative;
    width: 60px;
    height: 3px;
    background: rgba(255, 255, 255, 0.2);
    border: none;
    border-radius: 2px;
    cursor: pointer;
    padding: 0;
    overflow: hidden;
    transition: background 0.3s;
  }

  .shop-hero__indicator:hover {
    background: rgba(255, 255, 255, 0.35);
  }

  .shop-hero__indicator-fill {
    position: absolute;
    inset: 0;
    background: var(--primary-light, #4caf50);
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left;
  }

  .shop-hero__indicator.is-active .shop-hero__indicator-fill {
    animation: indicatorFill 6s linear forwards;
  }

  @keyframes indicatorFill {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  /* CTA */
  .shop-hero__cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: var(--space-md);
    margin-top: var(--space-3xl);
    opacity: 0;
  }

  .shop-hero__cta-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-2xl);
    font-size: var(--font-size-sm);
    font-weight: 500;
    letter-spacing: 0.05em;
    border-radius: var(--radius-full);
    transition: all var(--transition-base);
    text-decoration: none;
    cursor: pointer;
  }

  .shop-hero__cta-btn--primary {
    color: #fff;
    background: var(--primary-light, #4caf50);
    border: 1px solid var(--primary-light, #4caf50);
  }

  .shop-hero__cta-btn--primary:hover {
    background: #43a047;
    border-color: #43a047;
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(76, 175, 80, 0.3);
  }

  .shop-hero__cta-btn--secondary {
    color: var(--text-primary);
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.25);
  }

  .shop-hero__cta-btn--secondary:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .shop-hero__cta-btn--chat {
    color: var(--primary-light, #4caf50);
    background: transparent;
    border: 1px solid rgba(76, 175, 80, 0.35);
  }

  .shop-hero__cta-btn--chat:hover {
    background: rgba(76, 175, 80, 0.1);
    border-color: rgba(76, 175, 80, 0.6);
  }

  .shop-hero__cta-btn--chat svg {
    color: var(--primary-light, #4caf50);
  }

  .shop-hero__cta-btn svg {
    transition: transform var(--transition-base);
  }

  .shop-hero__cta-btn:hover svg {
    transform: translateX(4px);
  }

  /* Category Products Showcase — Marquee */
  .shop-hero__showcase {
    --card-w: 180px;
    --card-gap: 16px;
    width: 100%;
    margin-top: var(--space-xl);
    overflow: hidden;
    mask-image: linear-gradient(
      90deg,
      transparent 0%,
      #000 10%,
      #000 90%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0%,
      #000 10%,
      #000 90%,
      transparent 100%
    );
    opacity: 0;
  }

  .shop-hero__showcase-track {
    display: flex;
    gap: var(--card-gap);
    animation: showcaseMarquee 36s linear infinite;
  }

  .shop-hero__showcase:hover .shop-hero__showcase-track {
    animation-play-state: paused;
  }

  @keyframes showcaseMarquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc((var(--card-w) + var(--card-gap)) * -6)); }
  }

  .shop-hero__product-card {
    flex: 0 0 var(--card-w);
    display: flex;
    flex-direction: column;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    transition: background 0.3s, border-color 0.3s;
    cursor: pointer;
  }

  .shop-hero__product-card:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(76, 175, 80, 0.3);
  }

  .shop-hero__product-img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .shop-hero__product-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .shop-hero__product-card:hover .shop-hero__product-img {
    transform: scale(1.08);
  }

  .shop-hero__product-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-sm);
  }

  .shop-hero__product-category {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--primary-light, #4caf50);
  }

  .shop-hero__product-name {
    font-size: var(--font-size-xs);
    font-weight: 500;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Scroll Indicator */
  .shop-hero__scroll {
    position: absolute;
    bottom: var(--space-xl);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    opacity: 0;
    cursor: pointer;
    transition: opacity var(--transition-base);
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    outline: none;
  }

  .shop-hero__scroll:focus-visible {
    outline: 2px solid var(--primary-light, #4caf50);
    outline-offset: 4px;
    border-radius: 2px;
  }

  .shop-hero__scroll:hover {
    opacity: 0.8 !important;
  }

  .shop-hero__scroll-line {
    width: 1px;
    height: 48px;
    background: rgba(255, 255, 255, 0.15);
    position: relative;
    overflow: hidden;
  }

  .shop-hero__scroll-dot {
    width: 3px;
    height: 10px;
    background: var(--primary-light, #4caf50);
    border-radius: 2px;
    position: absolute;
    left: -1px;
    animation: shop-hero-scroll-pulse 2s ease-in-out infinite;
  }

  @keyframes shop-hero-scroll-pulse {
    0% { top: 0; opacity: 0.8; }
    50% { top: calc(100% - 10px); opacity: 0.3; }
    100% { top: 0; opacity: 0.8; }
  }

  /* Spinner for 3D preview loading */
  :global(@keyframes spin) {
    to { transform: rotate(360deg); }
  }

  /* ==================
     Responsive — Tablet (≤1023px): 1-column stack
     ================== */
  @media (max-width: 1023px) {
    .shop-hero__content {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .shop-hero__left {
      align-items: center;
      text-align: center;
    }

    .shop-hero__slides {
      min-height: 240px;
      justify-content: center;
    }

    .shop-hero__slide {
      align-items: center;
      text-align: center;
    }

    .shop-hero__headline {
      align-items: center;
      text-align: center;
    }

    .shop-hero__headline-text {
      font-size: clamp(3.15rem, 7.2vw, 5.4rem);
    }

    .shop-hero__desc {
      text-align: center;
      margin: 0 auto;
    }

    .shop-hero__cta {
      justify-content: center;
    }

    .shop-hero__simulator {
      max-width: 600px;
      min-height: 300px;
      margin: 0 auto;
    }
  }

  /* ==================
     Responsive — Mobile (≤719px)
     ================== */
  @media (max-width: 719px) {
    .shop-hero {
      min-height: auto;
      height: auto;
      padding: calc(var(--header-height, 64px) + var(--space-2xl)) 0 var(--space-xl);
    }

    .shop-hero__slides {
      min-height: 200px;
    }

    .shop-hero__headline-text {
      font-size: clamp(2.25rem, 9vw, 3.6rem);
    }

    .shop-hero__desc {
      font-size: var(--font-size-sm);
      max-width: 100%;
      padding: 0 var(--space-md);
    }

    .shop-hero__desc :global(.hide-mobile) {
      display: none;
    }

    .shop-hero__cta {
      flex-direction: row;
      flex-wrap: wrap;
      width: 100%;
      padding: 0 var(--space-md);
      gap: var(--space-sm);
      margin-top: var(--space-2xl);
    }

    .shop-hero__cta-btn {
      padding: var(--space-sm) var(--space-lg);
      font-size: var(--font-size-xs);
      letter-spacing: 0.02em;
    }

    .shop-hero__cta-btn--primary {
      flex: 1 1 100%;
      justify-content: center;
    }

    .shop-hero__cta-btn--secondary,
    .shop-hero__cta-btn--chat {
      flex: 1 1 0;
      justify-content: center;
    }

    .shop-hero__simulator {
      min-height: 220px;
    }

    .shop-hero__showcase {
      --card-w: 140px;
      --card-gap: 12px;
      margin-top: var(--space-lg);
    }

    .shop-hero__showcase-track {
      animation-duration: 28s;
    }

    .shop-hero__product-info {
      padding: var(--space-xs);
    }

    .shop-hero__product-name {
      font-size: 0.7rem;
    }

    .shop-hero__scroll {
      display: none;
    }

    .shop-hero__indicator {
      width: 44px;
    }
  }

  /* ==================
     Reduced Motion
     ================== */
  @media (prefers-reduced-motion: reduce) {
    .shop-hero__slide {
      transition: none;
    }

