<script>
  import { initShopHero, cleanupShopHero } from './shop-hero-animations';

  document.addEventListener('DOMContentLoaded', initShopHero);
  document.addEventListener('astro:page-load', initShopHero);
  document.addEventListener('astro:before-preparation', cleanupShopHero);

  // AI 상담 button → open chatbot
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-open-chat]');
    if (btn) window.dispatchEvent(new CustomEvent('open-chatbot'));
  });
</script>
