---
/**
 * LandingNavbar Component
 * Simplified navbar for landing page with logo and shop CTA
 */
---

<nav class="landing-navbar" id="landing-navbar">
  <div class="landing-navbar__blur">
    <div class="landing-navbar__blur-layer"></div>
  </div>

  <div class="landing-navbar__container">
    <!-- Logo -->
    <a href="/" class="landing-navbar__logo" aria-label="issac.design 홈">
      <span class="landing-navbar__logo-text">issac.design</span>
    </a>

    <!-- CTAs -->
    <div class="landing-navbar__ctas">
      <a href="/shop/login" class="landing-navbar__login" data-auth-login>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
          <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
        <span data-auth-label>로그인</span>
      </a>
      <a href="/shop" class="landing-navbar__cta">
        <span>쇼핑몰</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/>
          <path d="M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a href="/shop/simulator" class="landing-navbar__cta landing-navbar__cta--3d">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L2 7l10 5 10-5-10-5z"/>
          <path d="M2 17l10 5 10-5"/>
          <path d="M2 12l10 5 10-5"/>
        </svg>
        <span>3D 간판 체험하기</span>
      </a>
    </div>
  </div>
</nav>

<style>
  .landing-navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-fixed);
    height: var(--header-height);
    transition: background-color var(--transition-base);
  }

  /* Blur Background */
  .landing-navbar__blur {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .landing-navbar.scrolled .landing-navbar__blur {
    opacity: 1;
  }

  .landing-navbar__blur-layer {
    position: absolute;
    inset: 0;
    background: rgba(26, 26, 26, 0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Container */
  .landing-navbar__container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
    gap: var(--space-md);
  }

  /* Logo */
  .landing-navbar__logo {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
  }

  .landing-navbar__logo-text {
    font-family: var(--font-heading);
    font-size: var(--font-size-xl);
    font-weight: 700;
    letter-spacing: var(--letter-spacing-wide);
    color: var(--text-primary);
    transition: opacity var(--transition-base);
  }

  .landing-navbar__logo:hover .landing-navbar__logo-text {
    opacity: 0.8;
  }

  /* Login Button */
  .landing-navbar__login {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: var(--space-sm) var(--space-md);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-full);
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--text-secondary);
    transition: all var(--transition-base);
    white-space: nowrap;
  }

  .landing-navbar__login:hover {
    color: var(--text-primary);
    border-color: rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.05);
  }

  /* CTAs Wrapper */
  .landing-navbar__ctas {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  /* CTA Button */
  .landing-navbar__cta {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-sm) var(--space-lg);
    background: var(--primary);
    border-radius: var(--radius-full);
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: #FFFFFF;
    letter-spacing: var(--letter-spacing-tight);
    transition: all var(--transition-base);
    box-shadow: 0 4px 12px rgba(26, 77, 46, 0.3);
    white-space: nowrap;
  }

  .landing-navbar__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(26, 77, 46, 0.4);
  }

  .landing-navbar__cta:active {
    transform: translateY(0);
  }

  .landing-navbar__cta svg {
    width: 16px;
    height: 16px;
    transition: transform var(--transition-base);
  }

  .landing-navbar__cta:hover svg {
    transform: translateX(2px);
  }

  /* Responsive */
  @media (max-width: 719px) {
    .landing-navbar {
      height: var(--header-height-mobile);
    }

    .landing-navbar__logo-text {
      font-size: var(--font-size-lg);
    }

    .landing-navbar__ctas {
      gap: 6px;
    }

    .landing-navbar__login {
      padding: var(--space-xs) var(--space-sm);
      font-size: 11px;
      gap: 4px;
    }

    .landing-navbar__login svg {
      width: 12px;
      height: 12px;
    }

    .landing-navbar__cta {
      padding: var(--space-xs) var(--space-sm);
      font-size: 11px;
      gap: 4px;
    }

    .landing-navbar__cta svg {
      width: 12px;
      height: 12px;
    }
  }
</style>

<script>
  /**
   * Scroll effect for navbar
   */
  function initLandingNavbar() {
    const navbar = document.getElementById('landing-navbar');
    if (!navbar) return;

    let lastScroll = 0;

    const handleScroll = () => {
      const currentScroll = window.scrollY;

      if (currentScroll > 100) {
        navbar.classList.add('scrolled');
      } else {
        navbar.classList.remove('scrolled');
      }

      lastScroll = currentScroll;
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll(); // Initial check
  }

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLandingNavbar);
  } else {
    initLandingNavbar();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initLandingNavbar);
</script>
